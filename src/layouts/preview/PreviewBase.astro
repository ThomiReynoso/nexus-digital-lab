<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{negocio.nombre} — {negocio.barrio}</title>
  <meta name="description" content={`${negocio.tagline}. ${negocio.direccion}`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href={theme.fontImport} rel="stylesheet" />

  <style define:vars={{
    bg: theme.bg,
    bgAlt: theme.bgAlt,
    text: theme.text,
    textMuted: theme.textMuted,
    accent: theme.accent,
    accentGlow: theme.accentGlow,
    accentSoft: theme.accentSoft,
    gradient: theme.gradient,
    cardBg: theme.cardBg,
    cardBorder: theme.cardBorder,
    fontHeading: theme.fontHeading,
    fontBody: theme.fontBody,
  }}>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: auto; }

    body {
      font-family: var(--fontBody);
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ═══ GRAIN OVERLAY ═══ */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
      opacity: 0.03;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 256px;
    }

    /* ═══ PREVIEW BANNER ═══ */
    .preview-banner {
      position: relative;
      z-index: 200;
      background: rgba(26, 26, 46, 0.97);
      backdrop-filter: blur(12px);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 10px 20px;
      font-size: 13px;
      color: #e0e0e0;
      flex-wrap: wrap;
    }

    .preview-banner span { opacity: 0.8; }

    .preview-banner a {
      background: #7B6BB0;
      color: #fff;
      padding: 6px 16px;
      border-radius: 100px;
      text-decoration: none;
      font-weight: 600;
      font-size: 12px;
      transition: transform 0.2s, background 0.2s;
    }

    .preview-banner a:hover {
      background: #9484c9;
      transform: scale(1.05);
    }

    /* ═══ NAV ═══ */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 18px 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background 0.4s, padding 0.4s, box-shadow 0.4s, backdrop-filter 0.4s;
    }

    .nav.scrolled {
      background: color-mix(in srgb, var(--bg) 95%, transparent);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      padding: 12px 28px;
      box-shadow: 0 1px 0 var(--cardBorder), 0 4px 24px rgba(0,0,0,0.18);
    }

    .nav.has-banner { top: 0; }

    .nav-brand {
      font-family: var(--fontBody);
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--textMuted);
      text-decoration: none;
      opacity: 0;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .nav-actions {
      display: flex; gap: 10px; align-items: center;
      opacity: 0;
    }

    .nav-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 20px;
      border-radius: 100px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .nav-btn:hover { transform: translateY(-1px); }

    .nav-btn-outline {
      border: 1px solid var(--cardBorder);
      color: var(--text);
      background: transparent;
    }

    .nav-btn-outline:hover { border-color: var(--accent); }

    .nav-btn-primary {
      background: var(--accent);
      color: var(--bg);
      border: none;
    }

    .nav-btn-primary:hover { box-shadow: 0 8px 24px var(--accentGlow); }

    .nav-btn svg { width: 16px; height: 16px; fill: currentColor; }

    @media (max-width: 480px) {
      .nav-btn span { display: none; }
      .nav-btn { padding: 10px 14px; }
    }

    /* ═══ ABOUT ═══ */
    .about-inner {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 60px;
      align-items: start;
    }

    .about-label-col {
      padding-top: 8px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .about-accent-line {
      width: 2px;
      height: 60px;
      background: var(--accent);
      opacity: 0.4;
    }

    .about-title {
      font-family: var(--fontHeading);
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 28px;
    }

    .about-title em { font-style: italic; color: var(--accent); }

    .about-para {
      color: var(--textMuted);
      line-height: 1.75;
      font-size: 1rem;
      margin-bottom: 16px;
      opacity: 0;
      transform: translateY(20px);
    }

    .about-stats {
      display: flex;
      gap: 40px;
      margin-top: 40px;
      padding-top: 32px;
      border-top: 1px solid var(--cardBorder);
      flex-wrap: wrap;
    }

    .about-stat { display: flex; flex-direction: column; gap: 4px; }

    .about-stat-number {
      font-family: var(--fontHeading);
      font-size: 2rem;
      font-weight: 700;
      color: var(--text);
    }

    .about-stat-label {
      font-size: 12px;
      color: var(--textMuted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* ═══ HERO ═══ */
    .hero {
      min-height: 100vh;
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 120px 24px 140px;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--gradient);
      opacity: 0.7;
    }

    /* Animated gradient orb behind hero */
    .hero::after {
      content: '';
      position: absolute;
      width: 60vw;
      height: 60vw;
      max-width: 700px;
      max-height: 700px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
      opacity: 0.04;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: orbPulse 6s ease-in-out infinite;
    }

    @keyframes orbPulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.04; }
      50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.07; }
    }

    .hero-content { position: relative; z-index: 1; max-width: 800px; }

    .hero-location {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      color: var(--accent);
      font-weight: 500;
      letter-spacing: 0.05em;
      margin-bottom: 24px;
      opacity: 0;
      transform: translateY(30px);
    }

    .hero-location svg { width: 16px; height: 16px; fill: var(--accent); }

    .hero h1 {
      font-family: var(--fontHeading);
      font-size: clamp(2.5rem, 7vw, 5rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 20px;
    }

    /* SplitType chars start hidden */
    .hero h1 .char {
      display: inline-block;
      opacity: 0;
      transform: translateY(60px) rotateX(-40deg);
    }

    /* Keep word containers inline for wrapping */
    .hero h1 .word { display: inline-block; white-space: nowrap; }

    .hero-desc-block {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      margin-bottom: 24px;
      opacity: 0;
      transform: translateY(18px);
    }

    .hero-desc-line {
      width: 36px;
      height: 1px;
      background: var(--accent);
      opacity: 0.6;
    }

    .hero-description {
      font-family: var(--fontHeading);
      font-style: italic;
      font-size: clamp(0.95rem, 2vw, 1.1rem);
      color: var(--textMuted);
      line-height: 1.65;
      max-width: 460px;
      text-align: center;
    }

    .hero-gancho {
      font-family: var(--fontHeading);
      font-style: italic;
      font-size: clamp(1.1rem, 2.5vw, 1.35rem);
      color: var(--textMuted);
      line-height: 1.65;
      max-width: 520px;
      text-align: center;
    }

    .hero-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
      margin-bottom: 24px;
      opacity: 0;
      transform: translateY(20px);
    }

    .hero-pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 7px 16px;
      border-radius: 100px;
      border: 1px solid var(--cardBorder);
      background: var(--accentSoft);
      color: var(--textMuted);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.02em;
      white-space: nowrap;
    }

    .hero-pill::before {
      content: '';
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--accent);
      flex-shrink: 0;
    }

    .hero-rating {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: color-mix(in srgb, var(--accent) 8%, transparent);
      backdrop-filter: blur(8px);
      border: 1px solid var(--cardBorder);
      border-radius: 100px;
      padding: 8px 20px;
      font-size: 14px;
      margin-bottom: 36px;
      opacity: 0;
      transform: translateY(20px) scale(0.9);
    }

    .hero-rating .rating-stars { color: var(--accent); letter-spacing: 2px; }
    .hero-rating .rating-text { color: var(--textMuted); }
    .hero-rating strong { color: var(--text); }

    .hero-ctas {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
      opacity: 0;
      transform: translateY(25px);
    }

    .hero-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 32px;
      border-radius: 100px;
      font-family: var(--fontBody);
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      transition: transform 0.3s, box-shadow 0.3s;
      position: relative;
      overflow: hidden;
    }

    .hero-btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent, rgba(255,255,255,0.15), transparent);
      transform: translateX(-100%);
      transition: transform 0.6s;
    }

    .hero-btn:hover::after { transform: translateX(100%); }
    .hero-btn:hover { transform: translateY(-3px); }

    .hero-btn-primary {
      background: var(--accent);
      color: var(--bg);
    }

    .hero-btn-primary:hover {
      box-shadow: 0 16px 40px var(--accentGlow), 0 0 0 1px var(--accent);
    }

    .hero-btn-ghost {
      border: 1px solid var(--cardBorder);
      color: var(--text);
      background: color-mix(in srgb, var(--bg) 50%, transparent);
      backdrop-filter: blur(8px);
    }

    .hero-btn-ghost:hover { border-color: var(--accent); }

    .hero-btn svg { width: 20px; height: 20px; fill: currentColor; }

    /* ═══ FLOATING SHAPES ═══ */
    .floating-shapes { position: absolute; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
    .shape { position: absolute; border-radius: 50%; background: var(--accent); filter: blur(80px); }
    .shape-1 { width: 500px; height: 500px; top: -15%; right: -15%; opacity: 0.06; }
    .shape-2 { width: 350px; height: 350px; bottom: -10%; left: -10%; opacity: 0.05; }
    .shape-3 { width: 250px; height: 250px; top: 50%; left: 60%; opacity: 0.04; }
    .shape-4 { width: 180px; height: 180px; top: 20%; left: 15%; opacity: 0.03; background: var(--textMuted); filter: blur(60px); }

    /* ═══ SCROLL INDICATOR ═══ */
    .scroll-indicator {
      position: absolute;
      bottom: 32px; left: 50%;
      transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 8px;
      opacity: 0;
    }
    .scroll-indicator span { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--textMuted); }
    .scroll-line { width: 1px; height: 40px; background: var(--cardBorder); position: relative; overflow: hidden; }
    .scroll-line::after { content: ''; position: absolute; top: -100%; left: 0; width: 100%; height: 100%; background: var(--accent); animation: scrollAnim 2s ease-in-out infinite; }
    @keyframes scrollAnim { 0% { top: -100%; } 100% { top: 100%; } }

    /* ═══ DIVIDER ═══ */
    .section-divider {
      width: 100%;
      overflow: hidden;
      position: relative;
      height: 1px;
    }

    .section-divider .line {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      transform: scaleX(0);
    }

    /* ═══ SECTIONS ═══ */
    .section { padding: 120px 24px; position: relative; overflow: hidden; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-alt { background: var(--bgAlt); }

    .section-header { text-align: center; margin-bottom: 72px; }

    .section-label {
      font-size: 12px; font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.2em; text-transform: uppercase;
      margin-bottom: 16px;
      opacity: 0; transform: translateY(20px);
    }

    .section-title {
      font-family: var(--fontHeading);
      font-size: clamp(1.8rem, 4.5vw, 3rem);
      line-height: 1.12; letter-spacing: -0.03em;
      opacity: 0; transform: translateY(40px);
    }

    .section-title em { font-style: italic; color: var(--accent); }

    /* ═══ SERVICES ═══ */
    .services-visual-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .service-visual-card {
      position: relative;
      height: 340px;
      overflow: hidden;
      border-radius: 16px;
    }

    .service-visual-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
      display: block;
    }

    .service-visual-card:hover img { transform: scale(1.06); }

    .service-visual-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.1) 55%, transparent 100%);
    }

    .service-visual-content {
      position: absolute;
      bottom: 24px;
      left: 24px;
      right: 24px;
    }

    .service-visual-content h3 {
      font-family: var(--fontHeading);
      font-size: clamp(1.2rem, 3vw, 1.6rem);
      color: #fff;
      font-weight: 700;
      line-height: 1.15;
      margin-bottom: 6px;
    }

    .service-visual-content p {
      color: rgba(255,255,255,0.7);
      font-size: 13px;
      line-height: 1.45;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    @media (max-width: 600px) {
      .services-visual-list { grid-template-columns: 1fr; }
      .service-visual-card { height: 260px; }
    }

    /* ═══ REVIEWS ═══ */
    .reviews-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
    }

    @media (min-width: 768px) { .reviews-grid { grid-template-columns: repeat(3, 1fr); } }

    .review-card {
      background: color-mix(in srgb, var(--cardBg) 80%, transparent);
      backdrop-filter: blur(8px);
      border: 1px solid var(--cardBorder);
      border-radius: 20px;
      padding: 32px 28px;
      opacity: 0;
      transform: translateY(50px) scale(0.92);
      position: relative;
    }

    /* Big quote mark */
    .review-card::before {
      content: '"';
      position: absolute;
      top: 16px;
      right: 24px;
      font-family: var(--fontHeading);
      font-size: 5rem;
      line-height: 1;
      color: var(--accent);
      opacity: 0.08;
      pointer-events: none;
    }

    .review-stars {
      color: var(--accent);
      font-size: 1rem;
      letter-spacing: 2px;
      margin-bottom: 18px;
    }

    .review-text {
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--text);
      margin-bottom: 20px;
      font-style: italic;
    }

    .review-author {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--textMuted);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .review-author::before {
      content: '';
      width: 24px;
      height: 1px;
      background: var(--accent);
    }

    .reviews-badge {
      text-align: center;
      margin-top: 48px;
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }

    .reviews-badge-inner {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: color-mix(in srgb, var(--accent) 6%, transparent);
      backdrop-filter: blur(8px);
      border: 1px solid var(--cardBorder);
      border-radius: 100px;
      padding: 14px 28px;
      font-size: 14px;
    }

    .reviews-badge-inner .g-icon {
      font-size: 20px;
      font-weight: 700;
    }

    .reviews-badge-inner strong { color: var(--accent); }

    /* ═══ LOCATION ═══ */
    .location-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 40px;
      align-items: start;
    }

    @media (min-width: 768px) { .location-grid { grid-template-columns: 1.5fr 1fr; } }

    .map-wrapper {
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid var(--cardBorder);
      aspect-ratio: 16/10;
      opacity: 0;
      transform: translateX(-60px);
      box-shadow: 0 20px 60px rgba(0,0,0,0.06);
    }

    .map-wrapper iframe {
      width: 100%;
      height: 100%;
      border: 0;
      filter: grayscale(0.2) contrast(1.05);
    }

    .location-info {
      opacity: 0;
      transform: translateX(60px);
    }

    .location-item {
      padding: 22px 0;
      border-bottom: 1px solid var(--cardBorder);
    }

    .location-item:first-child { padding-top: 0; }
    .location-item:last-child { border-bottom: none; }

    .location-item-label {
      font-size: 11px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .location-item-value {
      font-size: 1rem;
      line-height: 1.5;
      color: var(--text);
    }

    .location-item-value a {
      color: var(--accent);
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .location-item-value a:hover { opacity: 0.8; }

    /* ═══ CTA ═══ */
    /* ═══ CONTACT ═══ */
    .contact-section { padding: 120px 24px; }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
      margin-top: 60px;
    }

    .contact-intro {
      color: var(--textMuted);
      line-height: 1.7;
      margin-bottom: 40px;
      font-size: 1rem;
    }

    .contact-channels { display: flex; flex-direction: column; gap: 12px; }

    .contact-channel {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 20px;
      border-radius: 12px;
      border: 1px solid var(--cardBorder);
      background: var(--cardBg);
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.2s, background 0.2s;
    }

    .contact-channel:not(.contact-channel--static):hover {
      border-color: var(--accent);
      background: var(--accentSoft);
    }

    .contact-channel-icon {
      width: 40px; height: 40px;
      border-radius: 10px;
      background: var(--accentSoft);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      color: var(--accent);
    }

    .contact-channel-icon svg { width: 18px; height: 18px; }

    .contact-channel-title {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--textMuted);
      margin-bottom: 2px;
    }

    .contact-channel-val { font-size: 14px; font-weight: 500; color: var(--text); }

    .contact-form-wrap {
      background: var(--cardBg);
      border: 1px solid var(--cardBorder);
      border-radius: 20px;
      padding: 40px;
    }

    .contact-form { display: flex; flex-direction: column; gap: 20px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }

    .form-group label {
      font-size: 12px;
      font-weight: 500;
      color: var(--textMuted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .form-group input,
    .form-group textarea {
      background: color-mix(in srgb, var(--bg) 60%, transparent);
      border: 1px solid var(--cardBorder);
      border-radius: 10px;
      padding: 14px 16px;
      color: var(--text);
      font-family: var(--fontBody);
      font-size: 15px;
      outline: none;
      transition: border-color 0.2s;
      resize: none;
      width: 100%;
    }

    .form-group input:focus,
    .form-group textarea:focus { border-color: var(--accent); }

    .form-group input::placeholder,
    .form-group textarea::placeholder { color: var(--textMuted); opacity: 0.6; }

    .form-submit {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px 28px;
      background: var(--accent);
      color: var(--bg);
      border: none;
      border-radius: 100px;
      font-family: var(--fontBody);
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
      width: 100%;
    }

    .form-submit:hover {
      opacity: 0.9;
      transform: translateY(-1px);
      box-shadow: 0 8px 24px var(--accentGlow);
    }

    .form-submit svg { width: 18px; height: 18px; }

    /* ═══ FOOTER ═══ */
    .footer {
      text-align: center;
      padding: 48px 24px;
      border-top: 1px solid var(--cardBorder);
    }

    .footer-brand {
      font-family: var(--fontHeading);
      font-size: 1.15rem;
      margin-bottom: 8px;
    }

    .footer-info {
      font-size: 13px;
      color: var(--textMuted);
      line-height: 1.7;
    }

    .footer-credit {
      margin-top: 28px;
      padding-top: 24px;
      border-top: 1px solid var(--cardBorder);
      font-size: 12px;
      color: var(--textMuted);
      opacity: 0.5;
    }

    .footer-credit a {
      color: var(--accent);
      text-decoration: none;
    }

    /* ═══ CALAX BOTTOM CTA ═══ */
    .calax-bottom-cta {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      padding: 80px 24px;
      text-align: center;
    }

    .calax-bottom-inner {
      max-width: 600px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }

    .calax-bottom-eyebrow {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #7B6BB0;
      font-weight: 600;
    }

    .calax-bottom-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      color: #fff;
      line-height: 1.15;
      letter-spacing: -0.02em;
    }

    .calax-bottom-sub {
      color: rgba(255,255,255,0.55);
      font-size: 1rem;
      line-height: 1.6;
      max-width: 480px;
    }

    .calax-bottom-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 32px;
      background: #7B6BB0;
      color: #fff;
      border-radius: 100px;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
      margin-top: 8px;
    }

    .calax-bottom-btn:hover {
      background: #9484c9;
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(123,107,176,0.4);
    }

    .calax-bottom-btn svg { width: 20px; height: 20px; }

    /* ═══ RESPONSIVE ═══ */
    @media (max-width: 767px) {
      .hero { padding: 110px 20px 60px; }
      .section { padding: 80px 20px; }
      .contact-section { padding: 80px 20px; }
      .hero h1 { font-size: clamp(2rem, 9vw, 3.2rem); }
      .scroll-indicator { display: none; }
      .about-inner { grid-template-columns: 1fr; gap: 24px; }
      .about-label-col { flex-direction: row; align-items: center; }
      .about-accent-line { display: none; }
      .about-stats { gap: 24px; }
      .contact-grid { grid-template-columns: 1fr; gap: 40px; }
      .contact-form-wrap { padding: 24px; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class={`nav ${isPreview ? 'has-banner' : ''}`}>
    <a href="#" class="nav-brand">{categoryLabel}</a>
    <div class="nav-actions">
      <a href="#servicios" class="nav-btn nav-btn-outline">Servicios</a>
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="nav-btn nav-btn-primary">
        <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span>WhatsApp</span>
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="floating-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
      <div class="shape shape-4"></div>
    </div>

    <div class="hero-content">
      <h1 data-split>{negocio.nombre}</h1>

      <div class="hero-pills">
        {negocio.especialidades.map((e) => (
          <span class="hero-pill">{e}</span>
        ))}
      </div>

      <div class="hero-desc-block">
        <div class="hero-desc-line"></div>
        <p class="hero-gancho">{gancho}</p>
      </div>

      <div class="hero-ctas">
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn-primary">
          <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Pedir cita
        </a>
        <a href="#servicios" class="hero-btn hero-btn-ghost">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
          Nuestros servicios
        </a>
      </div>
    </div>

    <div class="scroll-indicator">
      <span>Descubrí más</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider"><div class="line"></div></div>

  <!-- ABOUT -->
  <section class="section about-section" id="nosotros">
    <div class="section-inner about-inner">
      <div class="about-label-col">
        <p class="section-label">Sobre nosotros</p>
        <div class="about-accent-line"></div>
      </div>
      <div class="about-text-col">
        <h2 class="about-title" data-reveal>Nuestra <em>historia</em></h2>
        {historia.map((p) => (
          <p class="about-para">{p}</p>
        ))}
        <div class="about-stats">
          <div class="about-stat">
            <span class="about-stat-number">{negocio.resenas_count}+</span>
            <span class="about-stat-label">Clientes satisfechos</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-number">{negocio.rating}</span>
            <span class="about-stat-label">Puntuación Google</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-number">{negocio.barrio}</span>
            <span class="about-stat-label">Barcelona</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider"><div class="line"></div></div>

  <!-- SERVICES -->
  <section class="section section-alt" id="servicios">
    <div class="section-inner">
      <div class="section-header">
        <p class="section-label">Servicios</p>
        <h2 class="section-title" data-reveal>Nuestros <em>servicios</em></h2>
      </div>

      <div class="services-visual-list">
        {negocio.servicios.map((s, i) => (
          <div class="service-visual-card">
            <img
              src={serviceImages[i % serviceImages.length]}
              alt={s.nombre}
              loading="lazy"
            />
            <div class="service-visual-overlay"></div>
            <div class="service-visual-content">
              <h3>{s.nombre}</h3>
              <p>{s.descripcion}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider"><div class="line"></div></div>

  <!-- REVIEWS -->
  <section class="section" id="resenas">
    <div class="section-inner">
      <div class="section-header">
        <p class="section-label">Reseñas</p>
        <h2 class="section-title" data-reveal>Lo que dicen nuestros <em>clientes</em></h2>
      </div>

      <div class="reviews-grid">
        {negocio.resenas.map((r) => (
          <div class="review-card">
            <div class="review-stars">{stars(r.rating)}</div>
            <p class="review-text">{r.texto}</p>
            <span class="review-author">{r.autor}</span>
          </div>
        ))}
      </div>

      <div class="reviews-badge">
        <div class="reviews-badge-inner">
          <span class="g-icon">G</span>
          <span><strong>{negocio.rating}</strong> de 5 · {negocio.resenas_count} reseñas en Google</span>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider"><div class="line"></div></div>

  <!-- LOCATION -->
  <section class="section section-alt" id="ubicacion">
    <div class="section-inner">
      <div class="section-header">
        <p class="section-label">Ubicación</p>
        <h2 class="section-title" data-reveal>Dónde <em>encontrarnos</em></h2>
      </div>

      <div class="location-grid">
        <div class="map-wrapper">
          <iframe
            src={negocio.google_maps_embed}
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Mapa de ${negocio.nombre}`}
          ></iframe>
        </div>

        <div class="location-info">
          <div class="location-item">
            <p class="location-item-label">Dirección</p>
            <p class="location-item-value">{negocio.direccion}</p>
          </div>
          <div class="location-item">
            <p class="location-item-label">Teléfono</p>
            <p class="location-item-value">
              <a href={callUrl}>{negocio.telefono}</a>
            </p>
          </div>
          <div class="location-item">
            <p class="location-item-label">Horario</p>
            <p class="location-item-value">{negocio.horario}</p>
          </div>
          <div class="location-item">
            <p class="location-item-label">WhatsApp</p>
            <p class="location-item-value">
              <a href={whatsappUrl} target="_blank" rel="noopener noreferrer">Escribinos por WhatsApp</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider"><div class="line"></div></div>

  <!-- CONTACT -->
  <section class="contact-section section-alt" id="contacto">
    <div class="section-inner">
      <div class="section-header">
        <p class="section-label">Contacto</p>
        <h2 class="section-title" data-reveal>¿Hablamos?</h2>
      </div>

      <div class="contact-grid">
        <div class="contact-info">
          <p class="contact-intro">Estamos para responder tus preguntas, confirmar turnos y lo que necesites. Elegí el canal que más te guste.</p>

          <div class="contact-channels">
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="contact-channel">
              <div class="contact-channel-icon">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <div>
                <p class="contact-channel-title">WhatsApp</p>
                <p class="contact-channel-val">{negocio.telefono}</p>
              </div>
            </a>

            <a href={callUrl} class="contact-channel">
              <div class="contact-channel-icon">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              </div>
              <div>
                <p class="contact-channel-title">Llamada</p>
                <p class="contact-channel-val">{negocio.telefono}</p>
              </div>
            </a>

            <div class="contact-channel contact-channel--static">
              <div class="contact-channel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <p class="contact-channel-title">Ubicación</p>
                <p class="contact-channel-val">{negocio.barrio}, Barcelona</p>
              </div>
            </div>

            <div class="contact-channel contact-channel--static">
              <div class="contact-channel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div>
                <p class="contact-channel-title">Horario</p>
                <p class="contact-channel-val">{negocio.horario}</p>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-form-wrap">
          <form class="contact-form" id="contactForm" data-whatsapp={negocio.whatsapp}>
            <div class="form-group">
              <label for="cf-name">Tu nombre</label>
              <input type="text" id="cf-name" name="name" placeholder="¿Cómo te llamás?" autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="cf-phone">Teléfono</label>
              <input type="tel" id="cf-phone" name="phone" placeholder="+34 600 000 000" autocomplete="tel" />
            </div>
            <div class="form-group">
              <label for="cf-msg">Mensaje</label>
              <textarea id="cf-msg" name="message" rows="4" placeholder="¿En qué podemos ayudarte?"></textarea>
            </div>
            <button type="submit" class="form-submit">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Enviar por WhatsApp
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- CALAX BOTTOM CTA -->
  {isPreview && (
    <div class="calax-bottom-cta">
      <div class="calax-bottom-inner">
        <p class="calax-bottom-eyebrow">¿Tu negocio no tiene presencia online?</p>
        <h3 class="calax-bottom-title">Esta web podría ser tuya</h3>
        <p class="calax-bottom-sub">En Calax Studio diseñamos sitios web para negocios locales en Barcelona. Sin complicaciones, sin costos ocultos.</p>
        <a href={calaxWhatsapp} target="_blank" rel="noopener noreferrer" class="calax-bottom-btn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Hablemos por WhatsApp
        </a>
      </div>
    </div>
  )}

  <!-- FOOTER -->
  <footer class="footer">
    <p class="footer-brand">{negocio.nombre}</p>
    <p class="footer-info">
      {negocio.direccion}<br />
      {negocio.telefono} · {negocio.horario}
    </p>
    <p class="footer-credit">
      Diseñado por <a href="https://calaxstudio.com" target="_blank" rel="noopener noreferrer">Calax Studio</a>
    </p>
  </footer>

  <!-- GSAP + SplitType Animations -->
  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import SplitType from 'split-type';

    gsap.registerPlugin(ScrollTrigger);

    // ── SplitType on hero h1 ──
    const heroTitle = document.querySelector('[data-split]') as HTMLElement;
    let splitInstance: SplitType | null = null;

    if (heroTitle) {
      splitInstance = new SplitType(heroTitle, { types: 'words,chars' });
    }


    // ── Nav entrance ──
    const navTl = gsap.timeline({ delay: 0.3 });
    navTl
      .to('.nav-brand', { opacity: 1, duration: 0.6, ease: 'power3.out' })
      .to('.nav-actions', { opacity: 1, duration: 0.6, ease: 'power3.out' }, '<0.15');

    // ── Hero entrance timeline ──
    const heroTl = gsap.timeline({
      defaults: { ease: 'power3.out' },
      delay: 0.4,
    });

    heroTl
      // SplitType char-by-char reveal
      .to(splitInstance?.chars || [], {
        opacity: 1,
        y: 0,
        rotateX: 0,
        duration: 0.8,
        stagger: { amount: 0.6, from: 'start' },
        ease: 'back.out(1.5)',
      }, '-=0.3')
      .to('.hero-pills', { opacity: 1, y: 0, duration: 0.7 }, '-=0.3')
      .to('.hero-desc-block', { opacity: 1, y: 0, duration: 0.8 }, '-=0.3')
      .to('.hero-ctas', { opacity: 1, y: 0, duration: 0.7 }, '-=0.3')
      .to('.scroll-indicator', { opacity: 1, duration: 0.8 }, '-=0.2');

    // ── Counter animation ──
    const counterEl = document.querySelector('[data-count]');
    if (counterEl) {
      const target = parseInt(counterEl.getAttribute('data-count') || '0');
      gsap.to({ val: 0 }, {
        val: target,
        duration: 2.5,
        delay: 1.6,
        ease: 'power2.out',
        onUpdate: function () {
          counterEl.textContent = Math.round(this.targets()[0].val).toString();
        },
      });
    }

    // ── Nav scroll effect — fondo sólido desde 80px ──
    const nav = document.querySelector('.nav');
    let navScrolled = false;
    window.addEventListener('scroll', () => {
      const shouldScroll = window.scrollY > 80;
      if (shouldScroll !== navScrolled) {
        navScrolled = shouldScroll;
        nav?.classList.toggle('scrolled', shouldScroll);
      }
    }, { passive: true });

    // ── Section divider lines — animate scaleX on scroll ──
    gsap.utils.toArray('.section-divider .line').forEach((el: any) => {
      gsap.to(el, {
        scaleX: 1,
        duration: 1.2,
        ease: 'power3.inOut',
        scrollTrigger: { trigger: el, start: 'top 92%', toggleActions: 'play none none none' },
      });
    });

    // ── About paragraphs ──
    gsap.utils.toArray('.about-para').forEach((el: any, i: number) => {
      gsap.to(el, {
        opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
        delay: i * 0.12,
        scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
      });
    });

    // ── Section labels ──
    gsap.utils.toArray('.section-label').forEach((el: any) => {
      gsap.to(el, {
        opacity: 1, y: 0, duration: 0.6, ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
      });
    });

    // ── Section titles — SplitType word reveal ──
    gsap.utils.toArray('[data-reveal]').forEach((el: any) => {
      const split = new SplitType(el, { types: 'words' });
      gsap.fromTo(
        split.words || [],
        { opacity: 0, y: 30, rotateX: -20 },
        {
          opacity: 1, y: 0, rotateX: 0,
          duration: 0.7,
          stagger: 0.06,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
        }
      );
    });

    // ── Service visual cards — subtle scale reveal ──
    gsap.utils.toArray('.service-visual-card').forEach((el: any, i: number) => {
      gsap.fromTo(el,
        { opacity: 0, scale: 0.97 },
        {
          opacity: 1, scale: 1, duration: 0.7, ease: 'power3.out',
          delay: (i % 2) * 0.1,
          scrollTrigger: { trigger: el, start: 'top 90%', toggleActions: 'play none none none' },
        }
      );
    });

    // ── Review cards — dramatic scale + rotate entrance ──
    ScrollTrigger.batch('.review-card', {
      onEnter: (elements) => {
        gsap.to(elements, {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.9,
          stagger: 0.12,
          ease: 'back.out(1.2)',
        });
      },
      start: 'top 88%',
    });

    // ── Reviews badge ──
    gsap.to('.reviews-badge', {
      opacity: 1, y: 0, scale: 1, duration: 0.7, ease: 'back.out(1.5)',
      scrollTrigger: { trigger: '.reviews-badge', start: 'top 90%', toggleActions: 'play none none none' },
    });

    // ── Map — slide in from left ──
    gsap.to('.map-wrapper', {
      opacity: 1, x: 0, duration: 1, ease: 'power3.out',
      scrollTrigger: { trigger: '.map-wrapper', start: 'top 82%', toggleActions: 'play none none none' },
    });

    // ── Location info — slide in from right ──
    gsap.to('.location-info', {
      opacity: 1, x: 0, duration: 1, delay: 0.15, ease: 'power3.out',
      scrollTrigger: { trigger: '.location-info', start: 'top 82%', toggleActions: 'play none none none' },
    });

    // ── Contact form — WhatsApp submit ──
    const contactForm = document.getElementById('contactForm') as HTMLFormElement | null;
    if (contactForm) {
      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = (contactForm.querySelector('#cf-name') as HTMLInputElement).value.trim();
        const phone = (contactForm.querySelector('#cf-phone') as HTMLInputElement).value.trim();
        const msg = (contactForm.querySelector('#cf-msg') as HTMLTextAreaElement).value.trim();
        const whatsapp = contactForm.getAttribute('data-whatsapp') || '';
        const text = `Hola, soy ${name || 'un cliente'}${phone ? ` (${phone})` : ''}. ${msg || 'Me gustaría más información.'}`;
        window.open(`https://wa.me/${whatsapp}?text=${encodeURIComponent(text)}`, '_blank');
      });
    }

    // ── Hero floating shapes parallax ──
    gsap.to('.shape-1', {
      y: -150, rotation: 10,
      scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 },
    });
    gsap.to('.shape-2', {
      y: -80, x: 50,
      scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 },
    });
    gsap.to('.shape-3', {
      y: -120, x: -30, scale: 0.7,
      scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 },
    });
    gsap.to('.shape-4', {
      y: -60, x: 40, scale: 1.3,
      scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 },
    });

  </script>
</body>
</html>
