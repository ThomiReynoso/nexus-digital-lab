---
interface Servicio {
  nombre: string;
  precio: string;
  descripcion: string;
}

interface Resena {
  autor: string;
  texto: string;
  rating: number;
}

interface Negocio {
  slug: string;
  nombre: string;
  categoria: string;
  tagline: string;
  barrio: string;
  direccion: string;
  telefono: string;
  whatsapp: string;
  google_maps_embed: string;
  horario: string;
  resenas_count: number;
  rating: number;
  servicios: Servicio[];
  resenas: Resena[];
}

interface Theme {
  name: string;
  bg: string;
  bgAlt: string;
  text: string;
  textMuted: string;
  accent: string;
  accentGlow: string;
  accentSoft: string;
  gradient: string;
  cardBg: string;
  cardBorder: string;
  fontHeading: string;
  fontBody: string;
  fontImport: string;
}

interface Props {
  negocio: Negocio;
  theme: Theme;
  isPreview?: boolean;
}

const { negocio, theme, isPreview = true } = Astro.props;

const whatsappUrl = `https://wa.me/${negocio.whatsapp}`;
const callUrl = `tel:${negocio.telefono.replace(/\s/g, '')}`;
const stars = (rating: number) => '★'.repeat(Math.floor(rating)) + (rating % 1 >= 0.5 ? '☆' : '');
const calaxWhatsapp = 'https://wa.me/34600000000?text=' + encodeURIComponent(`Hola Calax, vi la preview de ${negocio.nombre} y me interesa una web así para mi negocio.`);
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{negocio.nombre} — {negocio.barrio}, Barcelona</title>
  <meta name="description" content={`${negocio.tagline}. ${negocio.direccion}`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href={theme.fontImport} rel="stylesheet" />

  <style define:vars={{
    bg: theme.bg,
    bgAlt: theme.bgAlt,
    text: theme.text,
    textMuted: theme.textMuted,
    accent: theme.accent,
    accentGlow: theme.accentGlow,
    accentSoft: theme.accentSoft,
    gradient: theme.gradient,
    cardBg: theme.cardBg,
    cardBorder: theme.cardBorder,
    fontHeading: theme.fontHeading,
    fontBody: theme.fontBody,
  }}>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: auto; }

    body {
      font-family: var(--fontBody);
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ═══ GRAIN OVERLAY ═══ */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
      opacity: 0.03;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 256px;
    }

    /* ═══ PREVIEW BANNER ═══ */
    .preview-banner {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      background: rgba(26, 26, 46, 0.95);
      backdrop-filter: blur(12px);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 10px 20px;
      font-size: 13px;
      color: #e0e0e0;
      transform: translateY(-100%);
      flex-wrap: wrap;
    }

    .preview-banner span { opacity: 0.8; }

    .preview-banner a {
      background: #7B6BB0;
      color: #fff;
      padding: 6px 16px;
      border-radius: 100px;
      text-decoration: none;
      font-weight: 600;
      font-size: 12px;
      transition: transform 0.2s, background 0.2s;
    }

    .preview-banner a:hover {
      background: #9484c9;
      transform: scale(1.05);
    }

    /* ═══ NAV ═══ */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 18px 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background 0.4s, padding 0.4s, box-shadow 0.4s, backdrop-filter 0.4s;
    }

    .nav.scrolled {
      background: color-mix(in srgb, var(--bg) 85%, transparent);
      backdrop-filter: blur(16px);
      padding: 12px 28px;
      box-shadow: 0 4px 30px rgba(0,0,0,0.08);
    }

    .nav.has-banner { top: 40px; }

    .nav-brand {
      font-family: var(--fontHeading);
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--text);
      text-decoration: none;
      opacity: 0;
    }

    .nav-actions {
      display: flex; gap: 10px; align-items: center;
      opacity: 0;
    }

    .nav-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 20px;
      border-radius: 100px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .nav-btn:hover { transform: translateY(-1px); }

    .nav-btn-outline {
      border: 1px solid var(--cardBorder);
      color: var(--text);
      background: transparent;
    }

    .nav-btn-outline:hover { border-color: var(--accent); }

    .nav-btn-primary {
      background: var(--accent);
      color: var(--bg);
      border: none;
    }

    .nav-btn-primary:hover { box-shadow: 0 8px 24px var(--accentGlow); }

    .nav-btn svg { width: 16px; height: 16px; fill: currentColor; }

    @media (max-width: 480px) {
      .nav-btn span { display: none; }
      .nav-btn { padding: 10px 14px; }
    }

    /* ═══ HERO ═══ */
    .hero {
      min-height: 100vh;
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 120px 24px 80px;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--gradient);
      opacity: 0.7;
    }

    /* Animated gradient orb behind hero */
    .hero::after {
      content: '';
      position: absolute;
      width: 60vw;
      height: 60vw;
      max-width: 700px;
      max-height: 700px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
      opacity: 0.04;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: orbPulse 6s ease-in-out infinite;
    }

    @keyframes orbPulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.04; }
      50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.07; }
    }

    .hero-content { position: relative; z-index: 1; max-width: 800px; }

    .hero-location {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      color: var(--accent);
      font-weight: 500;
      letter-spacing: 0.05em;
      margin-bottom: 24px;
      opacity: 0;
      transform: translateY(30px);
    }

    .hero-location svg { width: 16px; height: 16px; fill: var(--accent); }

    .hero h1 {
      font-family: var(--fontHeading);
      font-size: clamp(2.5rem, 7vw, 5rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 20px;
    }

    /* SplitType chars start hidden */
    .hero h1 .char {
      display: inline-block;
      opacity: 0;
      transform: translateY(60px) rotateX(-40deg);
    }

    /* Keep word containers inline for wrapping */
    .hero h1 .word { display: inline-block; white-space: nowrap; }

    .hero-tagline {
      font-size: clamp(1.05rem, 2.5vw, 1.3rem);
      color: var(--textMuted);
      line-height: 1.5;
      max-width: 550px;
      margin: 0 auto 16px;
      opacity: 0;
      transform: translateY(25px);
    }

    .hero-rating {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: color-mix(in srgb, var(--accent) 8%, transparent);
      backdrop-filter: blur(8px);
      border: 1px solid var(--cardBorder);
      border-radius: 100px;
      padding: 8px 20px;
      font-size: 14px;
      margin-bottom: 36px;
      opacity: 0;
      transform: translateY(20px) scale(0.9);
    }

    .hero-rating .rating-stars { color: var(--accent); letter-spacing: 2px; }
    .hero-rating .rating-text { color: var(--textMuted); }
    .hero-rating strong { color: var(--text); }

    .hero-ctas {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
      opacity: 0;
      transform: translateY(25px);
    }

    .hero-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 32px;
      border-radius: 100px;
      font-family: var(--fontBody);
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      transition: transform 0.3s, box-shadow 0.3s;
      position: relative;
      overflow: hidden;
    }

    .hero-btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent, rgba(255,255,255,0.15), transparent);
      transform: translateX(-100%);
      transition: transform 0.6s;
    }

    .hero-btn:hover::after { transform: translateX(100%); }
    .hero-btn:hover { transform: translateY(-3px); }

    .hero-btn-primary {
      background: var(--accent);
      color: var(--bg);
    }

    .hero-btn-primary:hover {
      box-shadow: 0 16px 40px var(--accentGlow), 0 0 0 1px var(--accent);
    }

    .hero-btn-ghost {
      border: 1px solid var(--cardBorder);
      color: var(--text);
      background: color-mix(in srgb, var(--bg) 50%, transparent);
      backdrop-filter: blur(8px);
    }

    .hero-btn-ghost:hover { border-color: var(--accent); }

    .hero-btn svg { width: 20px; height: 20px; fill: currentColor; }

    /* ═══ FLOATING SHAPES ═══ */
    .floating-shapes { position: absolute; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
    .shape { position: absolute; border-radius: 50%; background: var(--accent); filter: blur(80px); }
    .shape-1 { width: 500px; height: 500px; top: -15%; right: -15%; opacity: 0.06; }
    .shape-2 { width: 350px; height: 350px; bottom: -10%; left: -10%; opacity: 0.05; }
    .shape-3 { width: 250px; height: 250px; top: 50%; left: 60%; opacity: 0.04; }
    .shape-4 { width: 180px; height: 180px; top: 20%; left: 15%; opacity: 0.03; background: var(--textMuted); filter: blur(60px); }

    /* ═══ SCROLL INDICATOR ═══ */
    .scroll-indicator {
      position: absolute;
      bottom: 32px; left: 50%;
      transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 8px;
      opacity: 0;
    }
    .scroll-indicator span { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--textMuted); }
    .scroll-line { width: 1px; height: 40px; background: var(--cardBorder); position: relative; overflow: hidden; }
    .scroll-line::after { content: ''; position: absolute; top: -100%; left: 0; width: 100%; height: 100%; background: var(--accent); animation: scrollAnim 2s ease-in-out infinite; }
    @keyframes scrollAnim { 0% { top: -100%; } 100% { top: 100%; } }

    /* ═══ DIVIDER ═══ */
    .section-divider {
      width: 100%;
      overflow: hidden;
      position: relative;
      height: 1px;
    }

    .section-divider .line {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      transform: scaleX(0);
    }

    /* ═══ SECTIONS ═══ */
    .section { padding: 120px 24px; position: relative; overflow: hidden; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-alt { background: var(--bgAlt); }

    .section-header { text-align: center; margin-bottom: 72px; }

    .section-label {
      font-size: 12px; font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.2em; text-transform: uppercase;
      margin-bottom: 16px;
      opacity: 0; transform: translateY(20px);
    }

    .section-title {
      font-family: var(--fontHeading);
      font-size: clamp(1.8rem, 4.5vw, 3rem);
      line-height: 1.12; letter-spacing: -0.03em;
      opacity: 0; transform: translateY(40px);
    }

    .section-title em { font-style: italic; color: var(--accent); }

    /* ═══ SERVICES ═══ */
    .services-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
    }

    @media (min-width: 640px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 960px) { .services-grid { grid-template-columns: repeat(3, 1fr); } }

    .service-card {
      background: color-mix(in srgb, var(--cardBg) 80%, transparent);
      backdrop-filter: blur(8px);
      border: 1px solid var(--cardBorder);
      border-radius: 20px;
      padding: 32px 28px;
      opacity: 0;
      transform: translateY(50px) rotateX(-5deg);
      transition: border-color 0.3s;
      position: relative;
      overflow: hidden;
    }

    /* Accent top line on cards */
    .service-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      transform: scaleX(0);
      transition: transform 0.5s ease;
    }

    .service-card:hover::before { transform: scaleX(1); }
    .service-card:hover { border-color: var(--accent); }

    .service-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 12px;
      gap: 12px;
    }

    .service-card h3 {
      font-family: var(--fontHeading);
      font-size: 1.15rem;
      line-height: 1.3;
    }

    .service-price {
      font-family: var(--fontHeading);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--accent);
      white-space: nowrap;
    }

    .service-card p {
      color: var(--textMuted);
      font-size: 0.9rem;
      line-height: 1.6;
    }

    /* ═══ REVIEWS ═══ */
    .reviews-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
    }

    @media (min-width: 768px) { .reviews-grid { grid-template-columns: repeat(3, 1fr); } }

    .review-card {
      background: color-mix(in srgb, var(--cardBg) 80%, transparent);
      backdrop-filter: blur(8px);
      border: 1px solid var(--cardBorder);
      border-radius: 20px;
      padding: 32px 28px;
      opacity: 0;
      transform: translateY(50px) scale(0.92);
      position: relative;
    }

    /* Big quote mark */
    .review-card::before {
      content: '"';
      position: absolute;
      top: 16px;
      right: 24px;
      font-family: var(--fontHeading);
      font-size: 5rem;
      line-height: 1;
      color: var(--accent);
      opacity: 0.08;
      pointer-events: none;
    }

    .review-stars {
      color: var(--accent);
      font-size: 1rem;
      letter-spacing: 2px;
      margin-bottom: 18px;
    }

    .review-text {
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--text);
      margin-bottom: 20px;
      font-style: italic;
    }

    .review-author {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--textMuted);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .review-author::before {
      content: '';
      width: 24px;
      height: 1px;
      background: var(--accent);
    }

    .reviews-badge {
      text-align: center;
      margin-top: 48px;
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }

    .reviews-badge-inner {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: color-mix(in srgb, var(--accent) 6%, transparent);
      backdrop-filter: blur(8px);
      border: 1px solid var(--cardBorder);
      border-radius: 100px;
      padding: 14px 28px;
      font-size: 14px;
    }

    .reviews-badge-inner .g-icon {
      font-size: 20px;
      font-weight: 700;
    }

    .reviews-badge-inner strong { color: var(--accent); }

    /* ═══ LOCATION ═══ */
    .location-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 40px;
      align-items: start;
    }

    @media (min-width: 768px) { .location-grid { grid-template-columns: 1.5fr 1fr; } }

    .map-wrapper {
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid var(--cardBorder);
      aspect-ratio: 16/10;
      opacity: 0;
      transform: translateX(-60px);
      box-shadow: 0 20px 60px rgba(0,0,0,0.06);
    }

    .map-wrapper iframe {
      width: 100%;
      height: 100%;
      border: 0;
      filter: grayscale(0.2) contrast(1.05);
    }

    .location-info {
      opacity: 0;
      transform: translateX(60px);
    }

    .location-item {
      padding: 22px 0;
      border-bottom: 1px solid var(--cardBorder);
    }

    .location-item:first-child { padding-top: 0; }
    .location-item:last-child { border-bottom: none; }

    .location-item-label {
      font-size: 11px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .location-item-value {
      font-size: 1rem;
      line-height: 1.5;
      color: var(--text);
    }

    .location-item-value a {
      color: var(--accent);
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .location-item-value a:hover { opacity: 0.8; }

    /* ═══ CTA ═══ */
    .cta-section {
      padding: 140px 24px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .cta-section::before {
      content: '';
      position: absolute; inset: 0;
      background: var(--gradient);
      opacity: 0.5;
    }

    /* CTA floating orbs */
    .cta-orb {
      position: absolute;
      border-radius: 50%;
      background: var(--accent);
      filter: blur(100px);
      pointer-events: none;
    }
    .cta-orb-1 { width: 300px; height: 300px; top: -20%; left: -10%; opacity: 0.06; }
    .cta-orb-2 { width: 400px; height: 400px; bottom: -30%; right: -15%; opacity: 0.05; }

    .cta-content { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }

    .cta-title {
      font-family: var(--fontHeading);
      font-size: clamp(2.2rem, 5.5vw, 3.5rem);
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin-bottom: 18px;
      opacity: 0; transform: translateY(40px);
    }

    .cta-subtitle {
      color: var(--textMuted);
      font-size: 1.1rem;
      line-height: 1.6;
      margin-bottom: 40px;
      opacity: 0; transform: translateY(25px);
    }

    .cta-buttons {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
      opacity: 0; transform: translateY(25px);
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 18px 40px;
      border-radius: 100px;
      font-family: var(--fontBody);
      font-size: 1.05rem;
      font-weight: 600;
      text-decoration: none;
      transition: transform 0.3s, box-shadow 0.3s;
      position: relative;
      overflow: hidden;
    }

    .cta-btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent, rgba(255,255,255,0.15), transparent);
      transform: translateX(-100%);
      transition: transform 0.6s;
    }

    .cta-btn:hover::after { transform: translateX(100%); }
    .cta-btn:hover { transform: translateY(-3px); }

    .cta-btn-wa { background: #25D366; color: #fff; }
    .cta-btn-wa:hover { box-shadow: 0 16px 40px rgba(37, 211, 102, 0.35); }

    .cta-btn-call { background: var(--accent); color: var(--bg); }
    .cta-btn-call:hover { box-shadow: 0 16px 40px var(--accentGlow); }

    .cta-btn svg { width: 20px; height: 20px; fill: currentColor; }

    /* Glow ring pulse on WA button */
    .cta-btn-wa { animation: waPulse 3s ease-in-out infinite; }

    @keyframes waPulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.25); }
      50% { box-shadow: 0 0 0 12px rgba(37, 211, 102, 0); }
    }

    /* ═══ FOOTER ═══ */
    .footer {
      text-align: center;
      padding: 48px 24px;
      border-top: 1px solid var(--cardBorder);
    }

    .footer-brand {
      font-family: var(--fontHeading);
      font-size: 1.15rem;
      margin-bottom: 8px;
    }

    .footer-info {
      font-size: 13px;
      color: var(--textMuted);
      line-height: 1.7;
    }

    .footer-credit {
      margin-top: 28px;
      padding-top: 24px;
      border-top: 1px solid var(--cardBorder);
      font-size: 12px;
      color: var(--textMuted);
      opacity: 0.5;
    }

    .footer-credit a {
      color: var(--accent);
      text-decoration: none;
    }

    /* ═══ RESPONSIVE ═══ */
    @media (max-width: 767px) {
      .hero { padding: 110px 20px 60px; }
      .section { padding: 80px 20px; }
      .cta-section { padding: 80px 20px; }
      .hero h1 { font-size: clamp(2rem, 9vw, 3.2rem); }
    }
  </style>
</head>
<body>
  <!-- PREVIEW BANNER -->
  {isPreview && (
    <div class="preview-banner">
      <span>Vista previa creada por <strong>Calax Studio</strong></span>
