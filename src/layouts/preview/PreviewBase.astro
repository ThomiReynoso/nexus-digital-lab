  <!-- GSAP + SplitType Animations -->
  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import SplitType from 'split-type';

    gsap.registerPlugin(ScrollTrigger);

    // ── SplitType on hero h1 ──
    const heroTitle = document.querySelector('[data-split]') as HTMLElement;
    let splitInstance: SplitType | null = null;

    if (heroTitle) {
      splitInstance = new SplitType(heroTitle, { types: 'words,chars' });
    }

    // ── Preview banner ──
    gsap.to('.preview-banner', { y: 0, duration: 0.5, delay: 0.6, ease: 'power3.out',
      onStart: () => {
        const el = document.querySelector('.preview-banner') as HTMLElement;
        if (el) el.style.transform = 'translateY(-100%)';
      },
    });

    // ── Nav entrance ──
    const navTl = gsap.timeline({ delay: 0.3 });
    navTl
      .to('.nav-brand', { opacity: 1, duration: 0.6, ease: 'power3.out' })
      .to('.nav-actions', { opacity: 1, duration: 0.6, ease: 'power3.out' }, '<0.15');

    // ── Hero entrance timeline ──
    const heroTl = gsap.timeline({
      defaults: { ease: 'power3.out' },
      delay: 0.4,
    });

    heroTl
      .to('.hero-location', { opacity: 1, y: 0, duration: 0.7 })
      // SplitType char-by-char reveal
      .to(splitInstance?.chars || [], {
        opacity: 1,
        y: 0,
        rotateX: 0,
        duration: 0.8,
        stagger: { amount: 0.6, from: 'start' },
        ease: 'back.out(1.5)',
      }, '-=0.3')
      .to('.hero-tagline', { opacity: 1, y: 0, duration: 0.8 }, '-=0.3')
      .to('.hero-rating', { opacity: 1, y: 0, scale: 1, duration: 0.6, ease: 'back.out(1.7)' }, '-=0.4')
      .to('.hero-ctas', { opacity: 1, y: 0, duration: 0.7 }, '-=0.3')
      .to('.scroll-indicator', { opacity: 1, duration: 0.8 }, '-=0.2');

    // ── Counter animation ──
    const counterEl = document.querySelector('[data-count]');
    if (counterEl) {
      const target = parseInt(counterEl.getAttribute('data-count') || '0');
      gsap.to({ val: 0 }, {
        val: target,
        duration: 2.5,
        delay: 1.6,
        ease: 'power2.out',
        onUpdate: function () {
          counterEl.textContent = Math.round(this.targets()[0].val).toString();
        },
      });
    }

    // ── Nav scroll effect ──
    const nav = document.querySelector('.nav');
    ScrollTrigger.create({
      trigger: '.hero',
      start: 'top top',
      end: 'bottom top',
      onLeave: () => nav?.classList.add('scrolled'),
      onEnterBack: () => nav?.classList.remove('scrolled'),
    });

    // ── Section divider lines — animate scaleX on scroll ──
    gsap.utils.toArray('.section-divider .line').forEach((el: any) => {
      gsap.to(el, {
        scaleX: 1,
        duration: 1.2,
        ease: 'power3.inOut',
        scrollTrigger: { trigger: el, start: 'top 92%', toggleActions: 'play none none none' },
      });
    });

    // ── Section labels ──
    gsap.utils.toArray('.section-label').forEach((el: any) => {
      gsap.to(el, {
        opacity: 1, y: 0, duration: 0.6, ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
      });
    });

    // ── Section titles — SplitType word reveal ──
    gsap.utils.toArray('[data-reveal]').forEach((el: any) => {
      const split = new SplitType(el, { types: 'words' });
      gsap.fromTo(
        split.words || [],
        { opacity: 0, y: 30, rotateX: -20 },
        {
          opacity: 1, y: 0, rotateX: 0,
          duration: 0.7,
          stagger: 0.06,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
        }
      );
    });

    // ── Service cards — stagger with 3D rotation ──
    ScrollTrigger.batch('.service-card', {
      onEnter: (elements) => {
        gsap.to(elements, {
          opacity: 1,
          y: 0,
          rotateX: 0,
          duration: 0.8,
          stagger: 0.08,
          ease: 'power3.out',
        });
      },
      start: 'top 88%',
    });

    // ── Review cards — dramatic scale + rotate entrance ──
    ScrollTrigger.batch('.review-card', {
      onEnter: (elements) => {
        gsap.to(elements, {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.9,
          stagger: 0.12,
          ease: 'back.out(1.2)',
        });
      },
      start: 'top 88%',
    });

    // ── Reviews badge ──
    gsap.to('.reviews-badge', {
      opacity: 1, y: 0, scale: 1, duration: 0.7, ease: 'back.out(1.5)',
      scrollTrigger: { trigger: '.reviews-badge', start: 'top 90%', toggleActions: 'play none none none' },
    });

    // ── Map — slide in from left ──
    gsap.to('.map-wrapper', {
      opacity: 1, x: 0, duration: 1, ease: 'power3.out',
      scrollTrigger: { trigger: '.map-wrapper', start: 'top 82%', toggleActions: 'play none none none' },
    });

    // ── Location info — slide in from right ──
    gsap.to('.location-info', {
      opacity: 1, x: 0, duration: 1, delay: 0.15, ease: 'power3.out',
      scrollTrigger: { trigger: '.location-info', start: 'top 82%', toggleActions: 'play none none none' },
    });

    // ── CTA section — timeline ──
    const ctaTl = gsap.timeline({
      defaults: { ease: 'power3.out' },
      scrollTrigger: { trigger: '.cta-section', start: 'top 70%', toggleActions: 'play none none none' },
    });
    ctaTl
      .to('.cta-title', { opacity: 1, y: 0, duration: 0.9 })
      .to('.cta-subtitle', { opacity: 1, y: 0, duration: 0.7 }, '-=0.5')
      .to('.cta-buttons', { opacity: 1, y: 0, duration: 0.7, ease: 'back.out(1.5)' }, '-=0.3');

    // ── CTA orbs parallax ──
    gsap.to('.cta-orb-1', {
      y: -80, x: 30,
      scrollTrigger: { trigger: '.cta-section', start: 'top bottom', end: 'bottom top', scrub: 1 },
    });
    gsap.to('.cta-orb-2', {
      y: 60, x: -40,
      scrollTrigger: { trigger: '.cta-section', start: 'top bottom', end: 'bottom top', scrub: 1 },
    });

    // ── Hero floating shapes parallax ──
    gsap.to('.shape-1', {
      y: -150, rotation: 10,
      scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 },
    });
    gsap.to('.shape-2', {
      y: -80, x: 50,
      scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 },
    });
    gsap.to('.shape-3', {
      y: -120, x: -30, scale: 0.7,
      scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 },
    });
    gsap.to('.shape-4', {
      y: -60, x: 40, scale: 1.3,
      scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 },
    });

    // ── 3D tilt on service cards (desktop only) ──
    if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
      document.querySelectorAll('.service-card').forEach((card) => {
        card.addEventListener('mousemove', (e: Event) => {
          const ev = e as MouseEvent;
          const rect = (card as HTMLElement).getBoundingClientRect();
          const x = (ev.clientX - rect.left) / rect.width - 0.5;
          const y = (ev.clientY - rect.top) / rect.height - 0.5;
          gsap.to(card, {
            rotateY: x * 8,
            rotateX: -y * 8,
            duration: 0.4,
            ease: 'power2.out',
            transformPerspective: 800,
          });
        });
        card.addEventListener('mouseleave', () => {
          gsap.to(card, { rotateY: 0, rotateX: 0, duration: 0.6, ease: 'elastic.out(1, 0.5)' });
        });
      });
    }
  </script>
</body>
