---
interface Servicio {
  nombre: string;
  precio: string;
  descripcion: string;
}

interface Resena {
  autor: string;
  texto: string;
  rating: number;
}

interface Negocio {
  slug: string;
  nombre: string;
  categoria: string;
  tagline: string;
  descripcion: string;
  especialidades: string[];
  barrio: string;
  direccion: string;
  telefono: string;
  whatsapp: string;
  google_maps_embed: string;
  horario: string;
  resenas_count: number;
  rating: number;
  servicios: Servicio[];
  resenas: Resena[];
}

interface Theme {
  name: string;
  bg: string;
  bgAlt: string;
  text: string;
  textMuted: string;
  accent: string;
  accentGlow: string;
  accentSoft: string;
  gradient: string;
  cardBg: string;
  cardBorder: string;
  fontHeading: string;
  fontBody: string;
  fontImport: string;
}

interface Props {
  negocio: Negocio;
  theme: Theme;
  isPreview?: boolean;
}

const { negocio, theme, isPreview = true } = Astro.props;

const whatsappUrl = `https://wa.me/${negocio.whatsapp}`;
const callUrl = `tel:${negocio.telefono.replace(/\s/g, '')}`;
const stars = (rating: number) => '★'.repeat(Math.floor(rating)) + (rating % 1 >= 0.5 ? '☆' : '');
const calaxWhatsapp = 'https://wa.me/34610085327?text=' + encodeURIComponent(`Hola Calax, vi la preview de ${negocio.nombre} y me interesa una web así para mi negocio.`);

