---
import PreviewBase from './PreviewBase.astro';

interface Props {
  negocio: any;
  isPreview?: boolean;
}

const { negocio, isPreview = true } = Astro.props;

const theme = {
  name: 'fisioterapia',
  bg: '#F8FAFE',
  bgAlt: '#EDF2F9',
  text: '#1A2B4A',
  textMuted: '#6B7D99',
  accent: '#3B82C4',
  accentGlow: 'rgba(59, 130, 196, 0.3)',
  accentSoft: 'rgba(59, 130, 196, 0.08)',
  gradient: 'radial-gradient(ellipse at 50% 0%, rgba(59, 130, 196, 0.06) 0%, transparent 70%)',
  cardBg: '#FFFFFF',
  cardBorder: 'rgba(59, 130, 196, 0.1)',
  fontHeading: "'DM Serif Display', Georgia, serif",
  fontBody: "'Inter', sans-serif",
  fontImport: 'https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&display=swap',
};
---

<PreviewBase negocio={negocio} theme={theme} isPreview={isPreview} />
