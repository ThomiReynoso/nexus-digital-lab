---
import PreviewBase from './PreviewBase.astro';

interface Props {
  negocio: any;
  isPreview?: boolean;
}

const { negocio, isPreview = true } = Astro.props;

const theme = {
  name: 'peluqueria',
  bg: '#0A0A0A',
  bgAlt: '#111111',
  text: '#F5F0E8',
  textMuted: '#A89F91',
  accent: '#D4A853',
  accentGlow: 'rgba(212, 168, 83, 0.3)',
  accentSoft: 'rgba(212, 168, 83, 0.1)',
  gradient: 'radial-gradient(ellipse at 50% 0%, rgba(212, 168, 83, 0.08) 0%, transparent 70%)',
  cardBg: 'rgba(255, 255, 255, 0.03)',
  cardBorder: 'rgba(212, 168, 83, 0.12)',
  fontHeading: "'Playfair Display', Georgia, serif",
  fontBody: "'DM Sans', sans-serif",
  fontImport: 'https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap',
};
---

<PreviewBase negocio={negocio} theme={theme} isPreview={isPreview} />
