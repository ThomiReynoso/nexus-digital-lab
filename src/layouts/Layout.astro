---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Calax Studio | Agencia Digital',
  description = 'Diseño web, contenido visual y automatización para negocios en Barcelona. Trabajás directamente con quienes hacen el trabajo.',
  image = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://calaxstudio.com');
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>if ('scrollRestoration' in history) history.scrollRestoration = 'manual';</script>
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Calax Studio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Preloader + animation styles -->
    <style>
      #preloader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #0A0A0A;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }
      #preloader-logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
      }
      #preloader-img {
        width: clamp(160px, 26vw, 260px);
        height: auto;
        margin-bottom: 24px;
        opacity: 0;
        transform: scale(0.75);
      }
      #preloader-brand {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(3rem, 8vw, 6rem);
        color: #F7F4EF;
        display: flex;
        gap: 0.05em;
        overflow: hidden;
      }
      #preloader-studio {
        font-family: var(--font-sans, 'DM Sans', sans-serif);
        font-size: clamp(0.9rem, 2vw, 1.2rem);
        font-weight: 300;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        color: rgba(247, 244, 239, 0.6);
        opacity: 0;
        transform: translateY(10px);
      }
      .slide-up-char {
        display: inline-block;
        transform: translateY(120%);
      }
      #page-load-green {
        position: absolute;
        left: 0; top: 0;
        height: 100%;
        width: 0;
        background: #7B6BB0;
      }
      #page-load-black {
        position: absolute;
        left: 0; top: 0;
        width: 100%;
        height: 0;
        background: #0A0A0A;
      }

      /* Hero content hidden until preloader exits — GSAP takes over */
      .hero-left {
        opacity: 1;
      }

      [data-animate] {
        will-change: transform, opacity;
      }

      /* ─── Custom cursor (mouse/trackpad only — never hides cursor on touch) ── */
      @media (hover: hover) and (pointer: fine) and (min-width: 769px) {
        body { cursor: none; }
        a, button { cursor: none; }
      }

      #cursor-dot {
        position: fixed;
        width: 6px;
        height: 6px;
        background: var(--color-cream);
        border-radius: 50%;
        pointer-events: none;
        z-index: 99999;
        transform: translate(-50%, -50%);
        opacity: 0.68;
        transition: width 0.2s, height 0.2s, background 0.2s, opacity 0.2s;
      }

      #cursor-ring {
        position: fixed;
        width: 36px;
        height: 36px;
        border: 1.5px solid rgba(247, 244, 239, 0.5);
        border-radius: 50%;
        pointer-events: none;
        z-index: 99998;
        transform: translate(-50%, -50%);
        opacity: 0.55;
      }

      body.cursor-hover #cursor-ring {
        width: 60px;
        height: 60px;
        border-color: var(--color-green);
        transition: width 0.3s, height 0.3s, border-color 0.3s;
      }
      body.cursor-hover #cursor-dot {
        width: 4px;
        height: 4px;
      }

      /* ─── Portfolio card 3D tilt ──────────────────────────────────────────── */
      .pcard {
        transform-style: preserve-3d;
        will-change: transform;
      }

      /* ─── Hide cursor elements on mobile ───────────────────────────────── */
      @media (max-width: 768px) {
        #cursor-dot, #cursor-ring { display: none; }
      }

      /* ─── Scroll indicator (right side dots) ──────────────────────────── */
      #scroll-indicator {
        position: fixed;
        right: 20px;
        top: 50%;
        transform: translateY(-50%);
        z-index: 9990;
        display: flex;
        flex-direction: column;
        gap: 12px;
        opacity: 0;
        transition: opacity 0.4s ease;
      }

      #scroll-indicator.visible {
        opacity: 1;
      }

      .scroll-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(247, 244, 239, 0.15);
        border: 1px solid rgba(247, 244, 239, 0.1);
        transition: all 0.4s ease;
        cursor: pointer;
        position: relative;
      }

      .scroll-dot:hover {
        background: rgba(247, 244, 239, 0.35);
      }

      .scroll-dot.active {
        background: var(--color-purple);
        border-color: var(--color-purple);
        box-shadow: 0 0 10px rgba(184, 169, 217, 0.4);
        transform: scale(1.3);
      }

      .scroll-dot-label {
        position: absolute;
        right: 20px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 10px;
        font-weight: 500;
        color: rgba(247, 244, 239, 0.6);
        white-space: nowrap;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
      }

      .scroll-dot:hover .scroll-dot-label {
        opacity: 1;
      }

      @media (max-width: 768px) {
        #scroll-indicator { display: none; }
      }
    </style>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=block"
      rel="stylesheet"
    />

    <!-- Structured data -->
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Calax Studio",
  "url": "https://calaxstudio.com",
  "logo": "https://calaxstudio.com/logo1.png",
  "description": "Agencia digital especializada en diseño web, contenido visual y automatización para negocios.",
  "email": "calaxstudio@gmail.com",
  "sameAs": [
    "https://instagram.com/calaxstudio"
  ],
  "areaServed": {
    "@type": "Place",
    "name": "Argentina"
  },
  "priceRange": "$$",
  "openingHours": "Mo-Fr 09:00-18:00",
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+54-9-11-6658-7697",
    "contactType": "customer service",
    "availableLanguage": ["Spanish"]
  }
}
</script>
  </head>
  <body>
    <!-- Page entry preloader -->
    <div id="preloader" aria-hidden="true">
      <div id="preloader-logo">
        <img id="preloader-img" src="/logo-simple.png" alt="Calax Studio logo" />
        <div id="preloader-brand">
          <span class="slide-up-char">C</span>
          <span class="slide-up-char">a</span>
          <span class="slide-up-char">l</span>
          <span class="slide-up-char">a</span>
          <span class="slide-up-char">X</span>
        </div>
        <div id="preloader-studio">studio</div>
      </div>
      <div id="page-load-green"></div>
      <div id="page-load-black"></div>
    </div>

    <div id="cursor-dot"></div>
    <div id="cursor-ring"></div>

    <!-- Scroll section indicator -->
    <nav id="scroll-indicator" aria-label="Navegación de secciones">
      <a class="scroll-dot" href="#hero" data-section="hero"><span class="scroll-dot-label">Inicio</span></a>
      <a class="scroll-dot" href="#servicios" data-section="servicios"><span class="scroll-dot-label">Servicios</span></a>
      <a class="scroll-dot" href="#portfolio" data-section="portfolio"><span class="scroll-dot-label">Portfolio</span></a>
      <a class="scroll-dot" href="#proceso" data-section="proceso"><span class="scroll-dot-label">Proceso</span></a>
      <a class="scroll-dot" href="#nosotros" data-section="nosotros"><span class="scroll-dot-label">Nosotros</span></a>
      <a class="scroll-dot" href="#contacto" data-section="contacto"><span class="scroll-dot-label">Contacto</span></a>
    </nav>

    <slot />

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import SplitType from 'split-type';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger);

      // ─── Reduced motion check (must run before preloader) ───────────────────────
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ─── Preloader safety fallback ───────────────────────────────────────────────
      function removePreloader() {
        const p = document.getElementById('preloader');
        if (p) {
          p.style.opacity = '0';
          p.style.transition = 'opacity 0.3s';
          setTimeout(() => {
            p.remove();
            document.body.style.overflow = '';
            document.dispatchEvent(new CustomEvent('preloader-done'));
          }, 300);
        } else {
          document.body.style.overflow = '';
          document.dispatchEvent(new CustomEvent('preloader-done'));
        }
      }

      // Always remove preloader after 4s at the latest
      const preloaderFallback = setTimeout(removePreloader, 4000);

      try {
        // ─── Lenis smooth scroll ──────────────────────────────────────────────────
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });

        // Connect Lenis → ScrollTrigger
        lenis.on('scroll', ScrollTrigger.update);

        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });
        gsap.ticker.lagSmoothing(0);

        // Refresh ScrollTrigger after Lenis takes over so pin spacers
        // are calculated against the correct total document height.
        ScrollTrigger.refresh();

        // ─── Preloader ────────────────────────────────────────────────────────────
        const preloader = document.getElementById('preloader');
        const chars = document.querySelectorAll('.slide-up-char');
        const greenWipe = document.getElementById('page-load-green');
        const blackWipe = document.getElementById('page-load-black');

        document.body.style.overflow = 'hidden';

        if (prefersReducedMotion || !preloader) {
          // Skip animation entirely for reduced-motion users or missing preloader
          clearTimeout(preloaderFallback);
          removePreloader();
        } else {
          // Wait for fonts before exiting — prevents FOUT flash on preloader exit
          await document.fonts.ready;

          const preloaderImg = document.getElementById('preloader-img');

          const tl = gsap.timeline({
            onComplete: () => {
              clearTimeout(preloaderFallback);
              preloader.remove();
              document.body.style.overflow = '';
              document.dispatchEvent(new CustomEvent('preloader-done'));
            }
          });

          tl
            // Logo appears first: scale + fade in
            .to(preloaderImg, {
              opacity: 1,
              scale: 1,
              duration: 0.55,
              ease: 'back.out(1.8)',
            })
            // Subtle pulse on logo while letters prepare
            .to(preloaderImg, {
              scale: 1.04,
              duration: 0.22,
              ease: 'power1.inOut',
              yoyo: true,
              repeat: 1,
            }, '-=0.05')
            // Letters slide up
            .to(chars, {
              y: '0%',
              duration: 0.5,
              stagger: 0.045,
              ease: 'power3.out',
            }, '-=0.1')
            // "studio" fades in
            .to('#preloader-studio', {
              opacity: 1,
              y: 0,
              duration: 0.3,
              ease: 'power2.out',
            }, '-=0.2')
            // Brief hold
            .to({}, { duration: 0.2 })
            // Logo + letters exit together
            .to(preloaderImg, {
              opacity: 0,
              scale: 0.8,
              duration: 0.28,
              ease: 'power2.in',
            }, '+=0')
            .to(chars, {
              y: '-120%',
              duration: 0.32,
              stagger: 0.03,
              ease: 'power3.in',
            }, '<0.05')
            // Green horizontal wipe
            .to(greenWipe, {
              width: '100vw',
              duration: 0.32,
              ease: 'power2.inOut',
            }, '-=0.15')
            // Black vertical wipe covers green
            .to(blackWipe, {
              height: '100vh',
              duration: 0.26,
              ease: 'power2.inOut',
            })
            // Fade out preloader
            .to(preloader, {
              autoAlpha: 0,
              duration: 0.2,
              ease: 'power1.out',
            });
        }

        // ─── CTA sparkle on hover ────────────────────────────────────────────────
        if (!prefersReducedMotion) {
          document.querySelectorAll<HTMLElement>('.btn-primary, .nav-cta, .form-submit').forEach((btn) => {
            btn.addEventListener('mouseenter', (e) => {
              const rect = btn.getBoundingClientRect();
              const cx = rect.left + rect.width / 2;
              const cy = rect.top + rect.height / 2;

              for (let i = 0; i < 7; i++) {
                const star = document.createElement('span');
                star.textContent = '✦';
                star.style.cssText = `
                  position: fixed;
                  pointer-events: none;
                  z-index: 99999;
                  font-size: ${8 + Math.random() * 6}px;
                  color: #C4B4E8;
                  left: ${cx}px;
                  top: ${cy}px;
                  transform: translate(-50%, -50%);
                  user-select: none;
                `;
                document.body.appendChild(star);

                const angle = (i / 7) * Math.PI * 2 + Math.random() * 0.4;
                const dist = 28 + Math.random() * 22;

                gsap.to(star, {
                  x: Math.cos(angle) * dist,
                  y: Math.sin(angle) * dist,
                  opacity: 0,
                  scale: 0.2,
                  duration: 0.55 + Math.random() * 0.2,
                  ease: 'power2.out',
                  onComplete: () => star.remove(),
                });
              }
            });
          });
        }

        // ─── Section entrance animations (ScrollTrigger.batch) ────────────────────
        if (!prefersReducedMotion) {
          gsap.set('[data-animate]', { autoAlpha: 0, y: 40 });

          ScrollTrigger.batch('[data-animate]', {
            onEnter: (elements) => {
              gsap.to(elements, {
                autoAlpha: 1,
                y: 0,
                duration: 0.8,
                stagger: 0.12,
                ease: 'power3.out',
              });
            },
            start: 'top 88%',
            once: true,
          });

          // ─── SplitType character text reveal (scrubbed to scroll) ──────────────
          // Skip .hero-title — its animation is handled in Hero.astro
          const splitTargets = document.querySelectorAll('[data-split-text]:not(.hero-title)');

          splitTargets.forEach((el) => {
            const split = new SplitType(el as HTMLElement, { types: 'chars,words' });

            gsap.fromTo(
              split.chars,
              { opacity: 0.15 },
              {
                opacity: 1,
                stagger: 0.05,
                ease: 'none',
                scrollTrigger: {
                  trigger: el,
                  start: 'top 85%',
                  end: 'top 20%',
                  scrub: 1,
                },
              }
            );
          });
        } else {
          // Reduced motion: ensure all animated elements are visible
          gsap.set('[data-animate]', { autoAlpha: 1, y: 0 });
          gsap.set('[data-split-text] .char', { opacity: 1 });
        }
      } catch (e) {
        console.error('Animation init error:', e);
        clearTimeout(preloaderFallback);
        removePreloader();
      }

      // ─── Custom cursor ──────────────────────────────────────────────────────────
      const dot = document.getElementById('cursor-dot');
      const ring = document.getElementById('cursor-ring');

      if (dot && ring) {
        let mouseX = 0, mouseY = 0;

        window.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          gsap.set(dot, { x: mouseX, y: mouseY });
          gsap.to(ring, { x: mouseX, y: mouseY, duration: 0.35, ease: 'power2.out' });
        });

        // Hover state on interactive elements
        document.querySelectorAll('a, button, [data-magnetic]').forEach(el => {
          el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
          el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
        });

        // Hide cursor when leaving window
        document.addEventListener('mouseleave', () => {
          gsap.to([dot, ring], { autoAlpha: 0, duration: 0.3 });
        });
        document.addEventListener('mouseenter', () => {
          gsap.to([dot, ring], { autoAlpha: 1, duration: 0.3 });
        });
      }

      // ─── Magnetic buttons ────────────────────────────────────────────────────────
      if (!prefersReducedMotion) document.querySelectorAll('.nav-cta, .hero-actions a, [data-magnetic]').forEach(el => {
        const strength = 0.3;

        el.addEventListener('mousemove', (e) => {
          const rect = el.getBoundingClientRect();
          const centerX = rect.left + rect.width / 2;
          const centerY = rect.top + rect.height / 2;
          const deltaX = (e.clientX - centerX) * strength;
          const deltaY = (e.clientY - centerY) * strength;
          gsap.to(el, { x: deltaX, y: deltaY, duration: 0.3, ease: 'power2.out' });
        });

        el.addEventListener('mouseleave', () => {
          gsap.to(el, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.4)' });
        });
      });

      // ─── Hero parallax ──────────────────────────────────────────────────────────
      const heroSection = document.querySelector('#hero');
      if (heroSection && !prefersReducedMotion) {
        // Blobs move at different rates
        gsap.to('.blob-1', {
          y: -120,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 1.5,
          },
        });

        gsap.to('.blob-2', {
          y: -60,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 2,
          },
        });

      }

      // ─── Portfolio card 3D tilt ──────────────────────────────────────────────────
      if (!prefersReducedMotion) document.querySelectorAll('.pcard').forEach(card => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          const rotateX = ((y - centerY) / centerY) * -8;
          const rotateY = ((x - centerX) / centerX) * 8;

          gsap.to(card, {
            rotateX,
            rotateY,
            transformPerspective: 800,
            ease: 'power1.out',
            duration: 0.4,
          });
        });

        card.addEventListener('mouseleave', () => {
          gsap.to(card, {
            rotateX: 0,
            rotateY: 0,
            duration: 0.6,
            ease: 'elastic.out(1, 0.5)',
          });
        });
      });

      // ─── Footer letter drop ──────────────────────────────────────────────────────
      const footerLetters = document.querySelectorAll('.footer-letter-inner');
      if (footerLetters.length && !prefersReducedMotion) {
        gsap.from(footerLetters, {
          y: '-110%',
          duration: 1,
          stagger: 0.06,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: '.footer',
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      }

      // ─── Number counters ────────────────────────────────────────────────────────
      document.querySelectorAll('[data-counter]').forEach(el => {
        const target = parseInt(el.getAttribute('data-counter') || '0', 10);
        const suffix = el.textContent?.replace(/[0-9]/g, '') || '';
        const obj = { val: 0 };

        ScrollTrigger.create({
          trigger: el,
          start: 'top 85%',
          once: true,
          onEnter: () => {
            gsap.to(obj, {
              val: target,
              duration: 1.5,
              ease: 'power2.out',
              onUpdate: () => {
                el.textContent = Math.round(obj.val) + suffix;
              },
            });
          },
        });
      });


      // ─── Horizontal Journey scroll (desktop only) ────────────────────────────────
      if (!prefersReducedMotion) {
        const mmJourney = gsap.matchMedia();

        mmJourney.add('(min-width: 1025px)', () => {
          const section = document.querySelector('.hj-section') as HTMLElement;
          const track = document.querySelector('.hj-track') as HTMLElement;

          if (!section || !track) return;

          const getDistance = () => track.scrollWidth - window.innerWidth;

          gsap.to(track, {
            x: () => -getDistance(),
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              pin: true,
              scrub: 1,
              end: () => `+=${getDistance()}`,
              invalidateOnRefresh: true,
            },
          });
        });
      }

      // ─── Hero image mouse parallax ────────────────────────────────────────────────
      const heroBgWrapper = document.querySelector('.hero-bg-wrapper') as HTMLElement;
      const heroEl = document.querySelector('#hero') as HTMLElement;

      if (heroBgWrapper && heroEl && !prefersReducedMotion) {
        heroEl.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = heroEl.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width - 0.5) * 18;
          const y = ((e.clientY - rect.top) / rect.height - 0.5) * 12;
          gsap.to(heroBgWrapper, {
            x,
            y,
            duration: 1.8,
            ease: 'power2.out',
            overwrite: 'auto',
          });
        });

        heroEl.addEventListener('mouseleave', () => {
          gsap.to(heroBgWrapper, {
            x: 0,
            y: 0,
            duration: 2,
            ease: 'power3.out',
          });
        });
      }

      // ─── Scroll section indicator ──────────────────────────────────────────────────
      const scrollIndicator = document.getElementById('scroll-indicator');
      const scrollDots = document.querySelectorAll('.scroll-dot');

      if (scrollIndicator && scrollDots.length) {
        // Show indicator after scrolling past hero
        ScrollTrigger.create({
          trigger: '#hero',
          start: 'bottom 80%',
          onEnter: () => scrollIndicator.classList.add('visible'),
          onLeaveBack: () => scrollIndicator.classList.remove('visible'),
        });

        // Track active section
        const sectionIds = ['hero', 'servicios', 'portfolio', 'proceso', 'nosotros', 'contacto'];
        sectionIds.forEach(id => {
          const section = document.getElementById(id);
          if (!section) return;

          ScrollTrigger.create({
            trigger: section,
            start: 'top center',
            end: 'bottom center',
            onEnter: () => setActiveDot(id),
            onEnterBack: () => setActiveDot(id),
          });
        });

        function setActiveDot(id: string) {
          scrollDots.forEach(d => d.classList.remove('active'));
          const active = document.querySelector(`.scroll-dot[data-section="${id}"]`);
          if (active) active.classList.add('active');
        }
      }

    </script>
  </body>
</html>
