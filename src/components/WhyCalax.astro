---
---

<section class="why-calax" id="por-que-calax">
  <div class="why-inner">
    <p class="why-label" data-animate>Por qué Calax</p>
    <h2 class="why-title" data-why-split-text>No somos una <em>agencia más.</em></h2>
    <p class="why-subtitle" data-why-subtitle>Antes de construir cualquier cosa, necesitamos entender cuáles son tus procesos y que falla.</p>

    <div class="why-grid">

      <div class="why-card" data-why-card>
        <div class="why-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="currentColor" stroke-width="1.5"/>
            <text x="14" y="19" text-anchor="middle" font-family="DM Serif Display, Georgia, serif" font-size="13" font-style="italic" fill="currentColor">1</text>
          </svg>
        </div>
        <h3 class="why-card-title">Tu problema primero</h3>
        <p class="why-card-desc">No arrancamos proponiendo cosas. Primero entendemos qué te está pasando, qué no está funcionando y qué necesitás de verdad.</p>
      </div>

      <div class="why-card" data-why-card>
        <div class="why-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="currentColor" stroke-width="1.5"/>
            <text x="14" y="19" text-anchor="middle" font-family="DM Serif Display, Georgia, serif" font-size="13" font-style="italic" fill="currentColor">2</text>
          </svg>
        </div>
        <h3 class="why-card-title">Después el afuera</h3>
        <p class="why-card-desc">Con esa base, construimos la web, el contenido y los sistemas que tu negocio necesita. Sin soluciones genéricas.</p>
      </div>

      <div class="why-card" data-why-card>
        <div class="why-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="currentColor" stroke-width="1.5"/>
            <text x="14" y="19" text-anchor="middle" font-family="DM Serif Display, Georgia, serif" font-size="13" font-style="italic" fill="currentColor">3</text>
          </svg>
        </div>
        <h3 class="why-card-title">Sin intermediarios</h3>
        <p class="why-card-desc">Trabajás directamente con quienes hacen el trabajo. Thomas en tecnología, Mai en contenido. Sin account managers ni cadena de teléfono roto.</p>
      </div>

      <div class="why-card" data-why-card>
        <div class="why-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="currentColor" stroke-width="1.5"/>
            <text x="14" y="19" text-anchor="middle" font-family="DM Serif Display, Georgia, serif" font-size="13" font-style="italic" fill="currentColor">4</text>
          </svg>
        </div>
        <h3 class="why-card-title">A tu ritmo</h3>
        <p class="why-card-desc">No todos los clientes llegan al mismo punto. Nos adaptamos a donde estás hoy — y construimos desde ahí.</p>
      </div>

    </div>
  </div>
</section>

<style>
  .why-calax {
    background: #0A0A0A;
    padding: clamp(60px, 8vw, 120px) clamp(24px, 4vw, 80px);
  }

  .why-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .why-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 237, 230, 0.5);
    margin-bottom: 16px;
  }

  .why-title {
    font-family: var(--font-serif);
    font-size: clamp(28px, 4vw, 44px);
    color: var(--color-cream);
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .why-title em {
    font-style: italic;
    color: var(--color-green);
  }

  .why-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(14px, 1.1vw, 16px);
    color: var(--color-ink-muted);
    line-height: 1.6;
    max-width: 520px;
    margin-bottom: 4rem;
    font-weight: 300;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .why-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: border-color 0.3s, background 0.3s;
  }

  .why-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(184, 169, 217, 0.25);
  }

  .why-icon {
    color: var(--color-purple);
    flex-shrink: 0;
  }

  .why-card-title {
    font-family: var(--font-serif);
    font-size: clamp(17px, 1.5vw, 20px);
    color: var(--color-cream);
    line-height: 1.2;
    margin: 0;
  }

  .why-card-desc {
    font-family: var(--font-sans);
    font-size: 14px;
    color: rgba(247, 244, 239, 0.65);
    line-height: 1.65;
    font-weight: 300;
    margin: 0;
  }

  @media (max-width: 900px) {
    .why-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .why-calax {
      padding: 4rem 1.25rem;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Cards start hidden — GSAP sets this immediately via JS.
     This fallback prevents a FOUC if the script is slightly delayed. */
  [data-why-card] {
    will-change: transform, opacity;
  }

  [data-why-subtitle] {
    will-change: filter, opacity, transform;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import SplitType from 'split-type';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ─── Set initial hidden states immediately (prevents flash) ──────
  if (!prefersReducedMotion) {
    const whyTitle = document.querySelector<HTMLElement>('.why-title[data-why-split-text]');
    if (whyTitle) {
      const split = new SplitType(whyTitle, { types: 'chars,words' });
      gsap.set(split.chars, { y: 30, opacity: 0 });
    }
    const whySubtitle = document.querySelector<HTMLElement>('[data-why-subtitle]');
    if (whySubtitle) gsap.set(whySubtitle, { opacity: 0, y: 18, filter: 'blur(6px)' });
    const whyCards = document.querySelectorAll<HTMLElement>('[data-why-card]');
    if (whyCards.length) gsap.set(whyCards, { autoAlpha: 0, scale: 0.94, y: 20 });
  }

  // ─── Init scroll triggers after Lenis + ScrollTrigger are ready ──
  function initWhyAnimations() {
    if (prefersReducedMotion) {
      gsap.set('[data-why-subtitle]', { opacity: 1, filter: 'blur(0px)', y: 0 });
      gsap.set('[data-why-card]', { autoAlpha: 1, scale: 1, y: 0 });
      gsap.set('.why-title .char', { opacity: 1, y: 0 });
      return;
    }

    // 1. Title chars
    const whyTitle = document.querySelector<HTMLElement>('.why-title[data-why-split-text]');
    if (whyTitle) {
      const chars = whyTitle.querySelectorAll<HTMLElement>('.char');
      ScrollTrigger.create({
        trigger: whyTitle,
        start: 'top 85%',
        once: true,
        onEnter: () => {
          gsap.to(chars, { y: 0, opacity: 1, duration: 0.55, stagger: 0.03, ease: 'power3.out' });
        },
      });
    }

    // 2. Subtitle blur + fade-up
    const whySubtitle = document.querySelector<HTMLElement>('[data-why-subtitle]');
    if (whySubtitle) {
      ScrollTrigger.create({
        trigger: whySubtitle,
        start: 'top 88%',
        once: true,
        onEnter: () => {
          gsap.to(whySubtitle, { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.9, ease: 'power2.out' });
        },
      });
    }

    // 3. Cards scale-in with stagger
    const whyCards = document.querySelectorAll<HTMLElement>('[data-why-card]');
    if (whyCards.length) {
      ScrollTrigger.create({
        trigger: '.why-grid',
        start: 'top 82%',
        once: true,
        onEnter: () => {
          gsap.to(whyCards, { autoAlpha: 1, scale: 1, y: 0, duration: 0.7, stagger: 0.14, ease: 'power3.out' });
        },
      });
    }
  }

  if (document.getElementById('preloader')) {
    document.addEventListener('preloader-done', initWhyAnimations, { once: true });
  } else {
    initWhyAnimations();
  }
</script>
