---
---

<section class="hero" id="hero">
  <!-- Background image -->
  <div class="hero-bg-wrapper">
    <img class="hero-bg-img" src="/hero3.webp" alt="" aria-hidden="true" />
  </div>
  <div class="hero-bg-overlay"></div>

  <!-- Background blobs -->
  <div class="hero-blob blob-1"></div>
  <div class="hero-blob blob-2"></div>

  <!-- Content -->
  <div class="hero-left">
    <div class="hero-tag">Agencia digital · Barcelona</div>
    <h1 class="hero-title">
      Tu negocio merece una <span class="text-purple">presencia digital</span> que lo <em>represente</em> de verdad
    </h1>
    <p class="hero-sub">
      Creamos tu web, producimos tu contenido visual y automatizamos tus procesos. Un equipo pequeño, resultados concretos, sin intermediarios.
    </p>
    <div class="hero-actions">
      <a href="#contacto" class="btn-primary">Solicitar auditoría gratuita →</a>
      <a href="#proceso" class="btn-secondary">Ver cómo trabajamos</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    position: relative;
    overflow: clip; /* clip decorative blobs/bg without clipping text in child stacking contexts */
  }

  .hero-bg-wrapper {
    position: absolute;
    inset: -8%;
    z-index: 0;
    will-change: transform;
    pointer-events: none;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    animation: kenburns 18s ease-in-out infinite alternate;
    transform-origin: center center;
    will-change: transform;
  }

  @keyframes kenburns {
    0%   { transform: scale(1.0) translate(0%, 0%); }
    33%  { transform: scale(1.07) translate(-1.5%, 0.5%); }
    66%  { transform: scale(1.04) translate(1%, -1%); }
    100% { transform: scale(1.09) translate(-0.5%, 1%); }
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 50%, transparent 0%, #0A0A0A 70%);
    z-index: 1;
    pointer-events: none;
  }

.hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.45;
    pointer-events: none;
  }

  .blob-1 {
    width: 500px;
    height: 500px;
    background: rgba(123, 107, 176, 0.35);
    top: -100px;
    right: -100px;
    animation: float 8s ease-in-out infinite;
  }

  .blob-2 {
    width: 400px;
    height: 400px;
    background: rgba(90, 138, 82, 0.25);
    bottom: -80px;
    left: 10%;
    animation: float 10s ease-in-out infinite 2s;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 48px;
    position: relative;
    z-index: 2;
    max-width: 720px;
    width: 100%;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-purple-light);
    color: var(--color-purple-deep);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 32px;
    width: fit-content;
  }

  .hero-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-purple-deep);
    display: inline-block;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5vw, 68px);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin-bottom: 28px;
    overflow: visible;
    word-break: normal;
    overflow-wrap: break-word;
  }

  /* SplitType char/word wrappers must not clip */
  .hero-title .char,
  .hero-title .word {
    overflow: visible;
  }

  /* Char hover interaction base */
  .hero-title .char {
    display: inline-block;
    transition: color 0.1s ease;
    will-change: transform, color;
    transform-style: preserve-3d;
  }

  .hero-title em {
    font-style: italic;
    color: rgba(134, 239, 172, 0.9); /* green — matches .btn-secondary text */
  }

  .hero-title .text-purple {
    color: var(--color-purple-deep); /* #7B6BB0 */
  }

  .hero-sub {
    font-size: 16px;
    font-weight: 300;
    color: var(--color-ink-muted);
    line-height: 1.7;
    max-width: 400px;
    margin-bottom: 44px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 80px;
    }

    .hero-left {
      padding: 60px 24px 60px;
    }

    .btn-secondary {
      display: none;
    }

    .hero-actions {
      width: 100%;
    }

    .btn-primary {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import SplitType from 'split-type';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ─── Wait for preloader to finish, then run hero choreography ──────────────
  function initHeroAnimations() {
    const heroTitle = document.querySelector('.hero-title') as HTMLElement;
    const heroTag = document.querySelector('.hero-tag') as HTMLElement;
    const heroSub = document.querySelector('.hero-sub') as HTMLElement;
    const heroActions = document.querySelector('.hero-actions') as HTMLElement;
    const ctaButtons = document.querySelectorAll('.hero-actions a');
    const blobs = document.querySelectorAll('.hero-blob');

    if (!heroTitle) return;

    // SplitType on the title for char-level animation
    const split = new SplitType(heroTitle, { types: 'chars,words' });
    const chars = split.chars || [];

    if (prefersReducedMotion) {
      // Make everything visible immediately
      gsap.set(heroTitle, { opacity: 1, y: 0 });
      gsap.set(chars, { opacity: 1 });
      return;
    }

    // ─── Set initial hidden states ────────────────────────────────────────────
    // heroTag is visible immediately — no hidden state set
    // Title (chars), subtitle, and CTA buttons are visible immediately — no hidden state set
    gsap.set(blobs, { scale: 0.5, opacity: 0 });

    // ─── Choreographed entrance timeline ──────────────────────────────────────
    const tl = gsap.timeline({ delay: 0.1 });

    // 1. heroTag appears immediately — no entrance tween needed

    // 2. Title, subtitle, and CTA buttons are already visible — no entrance tweens needed

    // 3. Blobs fade in with scale
    tl.to(blobs, {
      scale: 1,
      opacity: 0.45,
      duration: 1.2,
      stagger: 0.2,
      ease: 'power2.out',
    }, '-=0.6');

    // ─── Color wave + scale hover effect on title chars ───────────────────────
    const originalColors: string[] = [];
    chars.forEach((char) => {
      originalColors.push(window.getComputedStyle(char).color);
    });

    let isHovering = false;
    let rafId: number | null = null;
    let mouseX = 0;
    let mouseY = 0;

    const waveColor = '#FFFFFF';
    const maxDistance = 120; // px radius of influence

    function updateCharEffects() {
      if (!isHovering) return;

      chars.forEach((char, i) => {
        const rect = char.getBoundingClientRect();
        const charCenterX = rect.left + rect.width / 2;
        const charCenterY = rect.top + rect.height / 2;
        const dx = mouseX - charCenterX;
        const dy = mouseY - charCenterY;
        const distance = Math.sqrt(dx * dx + dy * dy);
        const proximity = Math.max(0, 1 - distance / maxDistance);

        if (proximity > 0) {
          // Color wave: blend towards white based on proximity
          const scaleFactor = 1 + proximity * 0.15; // up to 15% scale
          gsap.to(char, {
            color: waveColor,
            scale: scaleFactor,
            duration: 0.2,
            ease: 'power1.out',
            overwrite: 'auto',
          });
        } else {
          // Return to original color
          gsap.to(char, {
            color: originalColors[i],
            scale: 1,
            duration: 0.5,
            ease: 'power2.out',
            overwrite: 'auto',
          });
        }
      });

      rafId = requestAnimationFrame(updateCharEffects);
    }

    heroTitle.addEventListener('mousemove', (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;

      if (!isHovering) {
        isHovering = true;
        rafId = requestAnimationFrame(updateCharEffects);
      }
    });

    heroTitle.addEventListener('mouseleave', () => {
      isHovering = false;
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
      // Reset all chars to original state
      chars.forEach((char, i) => {
        gsap.to(char, {
          color: originalColors[i],
          scale: 1,
          duration: 0.6,
          ease: 'elastic.out(1, 0.5)',
          overwrite: 'auto',
        });
      });
    });

    // ─── Parallax on blobs via mousemove ──────────────────────────────────────
    const heroEl = document.querySelector('#hero') as HTMLElement;
    const blob1 = document.querySelector('.blob-1') as HTMLElement;
    const blob2 = document.querySelector('.blob-2') as HTMLElement;

    if (heroEl && blob1 && blob2) {
      heroEl.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = heroEl.getBoundingClientRect();
        const normX = (e.clientX - rect.left) / rect.width - 0.5;
        const normY = (e.clientY - rect.top) / rect.height - 0.5;

        gsap.to(blob1, {
          x: normX * 40,
          y: normY * 30,
          duration: 1.5,
          ease: 'power2.out',
          overwrite: 'auto',
        });
        gsap.to(blob2, {
          x: normX * -25,
          y: normY * -20,
          duration: 2,
          ease: 'power2.out',
          overwrite: 'auto',
        });
      });
    }
  }

  // Listen for the preloader-done event dispatched from Layout.astro,
  // or run immediately if preloader already finished / doesn't exist.
  if (document.getElementById('preloader')) {
    document.addEventListener('preloader-done', initHeroAnimations, { once: true });
    // Fallback: if preloader takes too long, init after 5s
    setTimeout(() => {
      document.removeEventListener('preloader-done', initHeroAnimations);
      initHeroAnimations();
    }, 5000);
  } else {
    initHeroAnimations();
  }
</script>

