---
---

<section class="hero" id="hero">
  <!-- Background image -->
  <div class="hero-bg-wrapper">
    <img class="hero-bg-img" src="/hero2.jpeg" alt="" aria-hidden="true" />
  </div>
  <div class="hero-bg-overlay"></div>

  <!-- Background blobs -->
  <div class="hero-blob blob-1"></div>
  <div class="hero-blob blob-2"></div>

  <!-- Content -->
  <div class="hero-left">
    <div class="hero-tag">Agencia digital · Barcelona</div>
    <h1 class="hero-title split-text" data-split-text>
      Tu negocio merece una <span class="text-purple">presencia digital</span> que lo <em>represente</em> de verdad
    </h1>
    <p class="hero-sub">
      Creamos tu web, producimos tu contenido visual y automatizamos tus procesos. Un equipo pequeño, resultados concretos, sin intermediarios.
    </p>
    <div class="hero-actions">
      <a href="#contacto" class="btn-primary">Solicitar auditoría gratuita →</a>
      <a href="#proceso" class="btn-secondary">Ver cómo trabajamos</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    position: relative;
    overflow: clip; /* clip decorative blobs/bg without clipping text in child stacking contexts */
  }

  .hero-bg-wrapper {
    position: absolute;
    inset: -8%;
    z-index: 0;
    will-change: transform;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    animation: kenburns 18s ease-in-out infinite alternate;
    transform-origin: center center;
    will-change: transform;
  }

  @keyframes kenburns {
    0%   { transform: scale(1.0) translate(0%, 0%); }
    33%  { transform: scale(1.07) translate(-1.5%, 0.5%); }
    66%  { transform: scale(1.04) translate(1%, -1%); }
    100% { transform: scale(1.09) translate(-0.5%, 1%); }
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 50%, transparent 0%, #0A0A0A 70%);
    z-index: 1;
    pointer-events: none;
  }

.hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.45;
    pointer-events: none;
  }

  .blob-1 {
    width: 500px;
    height: 500px;
    background: rgba(123, 107, 176, 0.35);
    top: -100px;
    right: -100px;
    animation: float 8s ease-in-out infinite;
  }

  .blob-2 {
    width: 400px;
    height: 400px;
    background: rgba(90, 138, 82, 0.25);
    bottom: -80px;
    left: 10%;
    animation: float 10s ease-in-out infinite 2s;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 48px;
    position: relative;
    z-index: 2;
    max-width: 720px;
    width: 100%;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-purple-light);
    color: var(--color-purple-deep);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 32px;
    width: fit-content;
    animation: fadeUp 0.6s ease both;
  }

  .hero-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-purple-deep);
    display: inline-block;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5vw, 68px);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin-bottom: 28px;
    animation: fadeUp 0.6s ease 0.1s both;
    overflow: visible;
    word-break: normal;
    overflow-wrap: break-word;
  }

  /* SplitType char/word wrappers must not clip */
  .hero-title .char,
  .hero-title .word {
    overflow: visible;
  }

  .hero-title em {
    font-style: italic;
    color: rgba(134, 239, 172, 0.9); /* green — matches .btn-secondary text */
  }

  .hero-title .text-purple {
    color: var(--color-purple-deep); /* #7B6BB0 */
  }

  .hero-sub {
    font-size: 16px;
    font-weight: 300;
    color: var(--color-ink-muted);
    line-height: 1.7;
    max-width: 400px;
    margin-bottom: 44px;
    animation: fadeUp 0.6s ease 0.2s both;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    align-items: center;
    animation: fadeUp 0.6s ease 0.3s both;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 80px;
    }

    .hero-left {
      padding: 60px 24px 60px;
    }
  }
</style>

