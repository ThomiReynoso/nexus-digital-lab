---
---

<section class="hero">
  <!-- Background image with Ken Burns animation -->
  <div class="hero-bg"></div>
  <div class="hero-bg-overlay"></div>

  <!-- Background blobs -->
  <div class="hero-blob blob-1"></div>
  <div class="hero-blob blob-2"></div>

  <!-- Left content -->
  <div class="hero-left">
    <div class="hero-tag">Agencia digital · Barcelona</div>
    <h1 class="hero-title">
      Ayudamos a tu negocio a <em>conectar</em> con más <span class="green">clientes</span>
    </h1>
    <p class="hero-sub">
      Diseñamos tu presencia digital, gestionamos tus redes y creamos contenido que convierte. Todo en un solo lugar.
    </p>
    <div class="hero-actions">
      <a href="#contacto" class="btn-primary">Empieza ahora</a>
      <a href="#servicios" class="btn-secondary">Ver servicios</a>
    </div>
  </div>

  <!-- Right visual -->
  <div class="hero-right">
    <div class="hero-card-stack">
      <div class="hcard hcard-1">
        <div class="hcard-icon">🌐</div>
        <div class="hcard-title">Desarrollo web profesional</div>
        <div class="hcard-desc">Páginas rápidas, modernas y pensadas para convertir visitas en clientes reales.</div>
      </div>
      <div class="hcard hcard-2">
        <div class="hcard-icon">📱</div>
        <div class="hcard-title">Gestión de redes</div>
        <div class="hcard-desc">Contenido que construye comunidad y genera ventas.</div>
      </div>
      <div class="hcard hcard-3">
        <div class="hcard-label">PROYECTOS</div>
        <div class="hcard-num">12+</div>
        <div class="hcard-sub">negocios creciendo</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/hero.jpg');
    background-size: cover;
    background-position: center;
    opacity: 0.8;
    animation: kenBurns 24s ease-in-out infinite alternate;
    will-change: transform;
    z-index: 0;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 50%, transparent 0%, #0A0A0A 70%);
    z-index: 1;
    pointer-events: none;
  }

  @keyframes kenBurns {
    0%   { transform: scale(1)    translate(0%, 0%); }
    25%  { transform: scale(1.06) translate(-1%, 0.5%); }
    50%  { transform: scale(1.1)  translate(-1.5%, -1%); }
    75%  { transform: scale(1.06) translate(0.5%, -0.5%); }
    100% { transform: scale(1.12) translate(1%, 1%); }
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.45;
    pointer-events: none;
  }

  .blob-1 {
    width: 500px;
    height: 500px;
    background: rgba(123, 107, 176, 0.35);
    top: -100px;
    right: -100px;
    animation: float 8s ease-in-out infinite;
  }

  .blob-2 {
    width: 400px;
    height: 400px;
    background: rgba(90, 138, 82, 0.25);
    bottom: -80px;
    left: 10%;
    animation: float 10s ease-in-out infinite 2s;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 48px;
    position: relative;
    z-index: 2;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-purple-light);
    color: var(--color-purple-deep);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 32px;
    width: fit-content;
    animation: fadeUp 0.6s ease both;
  }

  .hero-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-purple-deep);
    display: inline-block;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(42px, 5vw, 68px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin-bottom: 28px;
    animation: fadeUp 0.6s ease 0.1s both;
  }

  .hero-title em {
    font-style: italic;
    color: var(--color-purple-deep);
  }

  .hero-title .green {
    color: var(--color-green-deep);
  }

  .hero-sub {
    font-size: 16px;
    font-weight: 300;
    color: var(--color-ink-muted);
    line-height: 1.7;
    max-width: 400px;
    margin-bottom: 44px;
    animation: fadeUp 0.6s ease 0.2s both;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    align-items: center;
    animation: fadeUp 0.6s ease 0.3s both;
  }

  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 48px 80px 0;
    position: relative;
    z-index: 2;
    animation: fadeUp 0.8s ease 0.2s both;
  }

  /* Card stack */
  .hero-card-stack {
    position: relative;
    width: 360px;
    height: 420px;
  }

  .hcard {
    position: absolute;
    background: #1C1C1A;
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* Main card — dark with pulsing glow */
  .hcard-1 {
    width: 280px;
    top: 0;
    left: 0;
    transform: rotate(-3deg);
    background: var(--color-ink-soft);
    color: var(--color-cream);
    animation: pulse-ring 3s ease-out infinite;
  }

  .hcard-1 .hcard-icon {
    font-size: 28px;
    margin-bottom: 12px;
  }

  .hcard-1 .hcard-title {
    font-family: var(--font-serif);
    font-size: 18px;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .hcard-1 .hcard-desc {
    font-size: 12px;
    color: rgba(247, 244, 239, 0.55);
    line-height: 1.6;
  }

  .hcard-2 {
    width: 240px;
    bottom: 40px;
    right: 0;
    transform: rotate(2deg);
    background: #2A2340;
    border-color: rgba(123, 107, 176, 0.25);
  }

  .hcard-2 .hcard-icon {
    font-size: 24px;
    margin-bottom: 10px;
  }

  .hcard-2 .hcard-title {
    font-family: var(--font-serif);
    font-size: 16px;
    color: #FFFFFF;
    margin-bottom: 6px;
  }

  .hcard-2 .hcard-desc {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
  }

  .hcard-3 {
    width: 200px;
    bottom: 0;
    left: 20px;
    transform: rotate(-1deg);
    background: #1A2B18;
    border-color: rgba(90, 138, 82, 0.25);
  }

  .hcard-3 .hcard-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--color-green-deep);
    letter-spacing: 0.06em;
    margin-bottom: 8px;
  }

  .hcard-3 .hcard-num {
    font-family: var(--font-serif);
    font-size: 36px;
    color: #FFFFFF;
    line-height: 1;
  }

  .hcard-3 .hcard-sub {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 4px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 80px;
    }

    .hero-left {
      padding: 60px 24px 40px;
    }

    .hero-right {
      padding: 0 24px 60px;
      justify-content: flex-start;
    }

    .hero-card-stack {
      width: 300px;
      height: 360px;
    }

    .hcard-1 {
      width: 240px;
    }

    .hcard-2 {
      width: 200px;
    }

    .hcard-3 {
      width: 170px;
    }
  }
</style>
