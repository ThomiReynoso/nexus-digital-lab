---
---

<section class="services" id="servicios">
  <div class="services-inner">
    <p class="services-label" data-animate>Lo que hacemos</p>
    <h2 class="services-title" data-split-text>Todo lo que necesitás para <em>crecer online</em>, en un solo equipo</h2>

    <div class="services-grid">

      <!-- Card 1 — Desarrollo web (FEATURED) -->
      <div class="svc svc-1" data-svc style="background:#2a2a2a;" data-svc-card>
        <img src="/images/svc-1.jpg" alt="Desarrollo web" class="svc-img" />
        <div class="svc-content">
          <span class="svc-badge">
            01
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </span>
          <h3 class="svc-title">Desarrollo web</h3>
          <p class="svc-desc">Diseñamos y desarrollamos páginas web profesionales, rápidas y optimizadas para atraer clientes. Desde una landing page hasta una tienda online completa — cada proyecto está pensado para convertir.</p>
          <div class="svc-tags">
            <span class="svc-tag">Landing pages</span>
            <span class="svc-tag">E-commerce</span>
            <span class="svc-tag">Web corporativa</span>
            <span class="svc-tag">Reservas online</span>
          </div>
          <div class="svc-arrow">↗</div>
        </div>
      </div>

      <!-- Card 2 — Producción de contenido visual -->
      <div class="svc svc-2" data-svc style="background:#2d1f3d;" data-svc-card>
        <img src="/images/svc-2.jpg" alt="Contenido visual" class="svc-img" />
        <div class="svc-content">
          <span class="svc-badge">
            02
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
              <circle cx="12" cy="13" r="4"/>
            </svg>
          </span>
          <h3 class="svc-title">Producción de contenido visual</h3>
          <p class="svc-desc">Hacemos la sesión de fotos y video, editamos tus reels y posts, y te entregamos un calendario con el contenido listo para publicar. Vos solo subís. Nosotros nos encargamos del resto.</p>
          <div class="svc-tags">
            <span class="svc-tag">Fotografía</span>
            <span class="svc-tag">Reels</span>
            <span class="svc-tag">Posts</span>
            <span class="svc-tag">Calendario</span>
          </div>
        </div>
      </div>

      <!-- Card 3 — Foto y video profesional -->
      <div class="svc svc-3" data-svc style="background:#1a2e1a;" data-svc-card>
        <img src="/images/svc-3.jpg" alt="Foto y video" class="svc-img" />
        <div class="svc-content">
          <span class="svc-badge">
            03
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/>
              <line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/>
              <line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/>
            </svg>
          </span>
          <h3 class="svc-title">Foto y video profesional</h3>
          <p class="svc-desc">Contenido visual pensado para negocios: fotografía de producto, sesiones en negocio y video que comunican quién sos antes de que digas una palabra.</p>
          <div class="svc-tags">
            <span class="svc-tag">Fotografía de producto</span>
            <span class="svc-tag">Sesiones en negocio</span>
            <span class="svc-tag">Video</span>
          </div>
        </div>
      </div>

      <!-- Card 4 — Automatización de procesos -->
      <div class="svc svc-4" data-svc style="background:#3a2f1e;" data-svc-card>
        <div class="svc-flow">
          <div class="flow-app"><span class="flow-icon">💬</span><span>WhatsApp</span></div>
          <span class="flow-chevron">›</span>
          <div class="flow-app"><span class="flow-icon">✉️</span><span>Gmail</span></div>
          <span class="flow-chevron">›</span>
          <div class="flow-app"><span class="flow-icon">📊</span><span>Sheets</span></div>
          <span class="flow-chevron">›</span>
          <div class="flow-app"><span class="flow-icon">📄</span><span>Docs</span></div>
        </div>
        <div class="svc-content">
          <span class="svc-badge">
            04
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/>
              <line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/>
              <line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/>
              <line x1="17" y1="16" x2="23" y2="16"/>
            </svg>
          </span>
          <h3 class="svc-title">Automatización de procesos</h3>
          <p class="svc-desc">Conectamos tus herramientas para que trabajen solas: respuestas automáticas, gestión de leads, pedidos, notificaciones.</p>
          <div class="svc-tags">
            <span class="svc-tag">n8n</span>
            <span class="svc-tag">Integraciones</span>
            <span class="svc-tag">Flujos automáticos</span>
            <span class="svc-tag">Gestión de leads</span>
          </div>
        </div>
      </div>

      <!-- Card 5 — Estrategia digital -->
      <div class="svc svc-5" data-svc style="background:#1a1a1e;" data-svc-card>
        <img src="/images/svc-5.jpg" alt="Estrategia digital" class="svc-img" />
        <div class="svc-content">
          <span class="svc-badge">
            05
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
          </span>
          <h3 class="svc-title">Estrategia digital</h3>
          <p class="svc-desc">Definimos qué comunicar, a quién y cómo — para que cada acción tenga un propósito claro y resultados medibles.</p>
          <div class="svc-tags">
            <span class="svc-tag">Posicionamiento</span>
            <span class="svc-tag">Estrategia</span>
            <span class="svc-tag">Análisis de competencia</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .services {
    padding: 120px 40px;
    background: #0a0a0a;
  }

  .services-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .services-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 237, 230, 0.5);
    margin-bottom: 16px;
  }

  .services-title {
    font-family: var(--font-serif);
    font-size: clamp(28px, 4vw, 44px);
    color: #f0ede6;
    line-height: 1.15;
    margin-bottom: 48px;
    max-width: 640px;
  }

  .services-title em {
    font-style: italic;
    color: var(--color-purple);
    -webkit-text-fill-color: var(--color-purple);
    background: none;
    -webkit-background-clip: unset;
    background-clip: unset;
  }

  /* Grid */
  .services-grid {
    display: grid;
    grid-template-columns: 480fr 388fr 396fr;
    grid-template-rows: 374px 378px;
    gap: 8px;
    perspective: 1000px;
  }

  .svc-1 { grid-column: 1; grid-row: 1 / 3; }
  .svc-2 { grid-column: 2; grid-row: 1; }
  .svc-3 { grid-column: 3; grid-row: 1; }
  .svc-4 { grid-column: 2; grid-row: 2; }
  .svc-5 { grid-column: 3; grid-row: 2; }

  /* Base card */
  .svc {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    cursor: default;
    border: 1px solid rgba(255, 255, 255, 0.07);
    transition: border-color 0.3s;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .svc:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  /* Grain overlay */
  .svc::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.04;
    mix-blend-mode: overlay;
    pointer-events: none;
    z-index: 4;
  }

  /* Image */
  .svc-img {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    object-fit: cover;
    border-radius: 12px 12px 0 0;
    z-index: 1;
  }

  .svc-1 .svc-img { height: 45%; }
  .svc-2 .svc-img,
  .svc-3 .svc-img,
  .svc-5 .svc-img { height: 40%; }

  /* Image gradient fade */
  .svc::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .svc-1::before { background: linear-gradient(to bottom, transparent 20%, #2a2a2a 50%); }
  .svc-2::before { background: linear-gradient(to bottom, transparent 25%, #2d1f3d 55%); }
  .svc-3::before { background: linear-gradient(to bottom, transparent 25%, #1a2e1a 55%); }
  .svc-4::before { background: linear-gradient(to bottom, transparent 0%, #3a2f1e 40%); }
  .svc-5::before { background: linear-gradient(to bottom, transparent 25%, #1a1a1e 55%); }

  /* Content (above gradient) */
  .svc-content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Badge */
  .svc-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 4px 8px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 20px;
    width: fit-content;
    font-family: var(--font-sans);
    font-size: 11px;
    color: #f0ede6;
  }

  .svc-badge svg {
    width: 14px;
    height: 14px;
  }

  .svc-1 .svc-badge svg { color: #a09a8e; }
  .svc-2 .svc-badge svg { color: #b89fd4; }
  .svc-3 .svc-badge svg { color: #7ab896; }
  .svc-4 .svc-badge svg { color: #c49a4a; }
  .svc-5 .svc-badge svg { color: #a09a8e; }

  /* Title */
  .svc-title {
    font-family: var(--font-serif);
    color: #f0ede6;
    line-height: 1.15;
    margin: 0;
  }

  .svc-1 .svc-title { font-size: clamp(28px, 3vw, 40px); }
  .svc-2 .svc-title,
  .svc-3 .svc-title,
  .svc-4 .svc-title,
  .svc-5 .svc-title { font-size: 20px; }

  /* Desc */
  .svc-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    color: #a09a8e;
    line-height: 1.5;
    margin: 0;
  }

  /* Tags */
  .svc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 4px;
  }

  .svc-tag {
    font-family: var(--font-sans);
    font-size: 10px;
    color: #d0c8bc;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 6px;
    padding: 3px 8px;
  }

  .svc-3 .svc-tag { border-color: rgba(122, 184, 150, 0.35); }
  .svc-4 .svc-tag { border-color: rgba(196, 154, 74, 0.35); }

  /* Arrow button (Card 1 only) */
  .svc-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #f0ede6;
    font-size: 18px;
    margin-top: 8px;
    transition: border-color 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .svc:hover .svc-arrow {
    transform: translate(2px, -2px);
    border-color: rgba(255, 255, 255, 0.7);
  }

  /* Flow diagram (Card 4) */
  .svc-flow {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    padding: 10px 0;
    position: relative;
    z-index: 3;
  }

  .flow-app {
    display: flex;
    align-items: center;
    gap: 4px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 5px 10px;
    font-family: var(--font-sans);
    font-size: 11px;
    color: #d0c8bc;
  }

  .flow-chevron {
    color: rgba(255, 255, 255, 0.3);
    font-size: 16px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      gap: 8px;
    }

    .svc-1 { grid-column: 1 / 3; grid-row: auto; height: 340px; }
    .svc-2,
    .svc-3,
    .svc-4,
    .svc-5 { grid-column: auto; grid-row: auto; height: 280px; }
  }

  @media (max-width: 600px) {
    .services { padding: 80px 20px; }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .svc-1 { grid-column: 1; height: 320px; }
    .svc-1::before { background: linear-gradient(to bottom, transparent 15%, #2a2a2a 45%); }
    .svc-2,
    .svc-3,
    .svc-4,
    .svc-5 { height: 260px; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    // ─── Scroll-triggered entrance with stagger ──────────────────────────
    const svcCards = gsap.utils.toArray<HTMLElement>('[data-svc-card]');

    gsap.set(svcCards, {
      autoAlpha: 0,
      y: 60,
      rotateY: -5,
    });

    // Tags initial hide (will be revealed after card entrance)
    gsap.set('[data-svc-card] .svc-tag', { autoAlpha: 0, scale: 0.7 });

    ScrollTrigger.batch(svcCards, {
      onEnter: (batch) => {
        gsap.to(batch, {
          autoAlpha: 1,
          y: 0,
          rotateY: 0,
          duration: 0.9,
          stagger: 0.15,
          ease: 'back.out(1.4)',
          onComplete: () => {
            // After cards enter, animate tags inside each card
            batch.forEach((card: HTMLElement) => {
              const tags = card.querySelectorAll('.svc-tag');
              if (tags.length) {
                gsap.fromTo(
                  tags,
                  { autoAlpha: 0, scale: 0.7 },
                  {
                    autoAlpha: 1,
                    scale: 1,
                    duration: 0.35,
                    stagger: 0.05,
                    ease: 'back.out(1.7)',
                  }
                );
              }
            });
          },
        });
      },
      start: 'top 88%',
      once: true,
    });

    // ─── 3D tilt on mouse move ───────────────────────────────────────────
    svcCards.forEach((card) => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = ((y - centerY) / centerY) * -8;
        const rotateY = ((x - centerX) / centerX) * 8;

        gsap.to(card, {
          rotateX,
          rotateY,
          scale: 1.025,
          transformPerspective: 800,
          ease: 'power1.out',
          duration: 0.4,
        });
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          scale: 1,
          duration: 0.6,
          ease: 'elastic.out(1, 0.5)',
        });
      });
    });
  } else {
    // Reduced motion: make everything visible
    gsap.set('[data-svc-card]', { autoAlpha: 1, y: 0, rotateY: 0 });
    gsap.set('[data-svc-card] .svc-tag', { autoAlpha: 1, scale: 1 });
  }
</script>
