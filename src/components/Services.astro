---
---

<section class="services" id="servicios">
  <div class="services-header">
    <p class="services-label" data-animate>Lo que hacemos</p>
    <h2 class="services-title" data-split-text>Todo lo que tu negocio necesita para <em>crecer online</em>, en un solo equipo</h2>
  </div>

  <div class="services-track">

    <!-- Card 1 — Desarrollo web (FEATURED) -->
    <div class="svc svc-1" style="background:#2a2a2a;" data-svc-card>
      <img src="/images/svc-1.jpg" alt="Desarrollo web" class="svc-img" />
      <div class="svc-content">
        <span class="svc-badge">
          01
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </span>
        <h3 class="svc-title">Desarrollo web y mobile</h3>
        <p class="svc-desc">Diseñamos y desarrollamos sitios web y aplicaciones mobile profesionales, rápidas y optimizadas para atraer clientes. Cada proyecto es mobile first, con SEO técnico desde la base para que Google te encuentre. Desde una landing page hasta una tienda online completa — pensado para convertir.</p>
        <div class="svc-tags">
          <span class="svc-tag">Landing pages</span>
          <span class="svc-tag">E-commerce</span>
          <span class="svc-tag">Web corporativa</span>
          <span class="svc-tag">Reservas online</span>
          <span class="svc-tag">Mobile first</span>
          <span class="svc-tag">SEO</span>
          <span class="svc-tag">Performance</span>
        </div>
        <div class="svc-arrow">↗</div>
      </div>
    </div>

    <!-- Card 2 — Automatización de procesos -->
    <div class="svc svc-2" style="background:#3a2f1e;" data-svc-card>
      <img src="/images/svc-4.jpg" alt="Automatización de procesos" class="svc-img" />
      <div class="svc-content">
        <div class="svc-inline-header">
          <span class="svc-badge">
            02
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/>
              <line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/>
              <line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/>
              <line x1="17" y1="16" x2="23" y2="16"/>
            </svg>
          </span>
          <h3 class="svc-title">Automatización de procesos</h3>
        </div>
        <p class="svc-desc">Si hoy tu negocio depende de que estés en todo… algo no está funcionando bien. Automatizamos procesos para que ganes tiempo, orden y tranquilidad.</p>
        <div class="svc-tags">
          <span class="svc-tag">n8n</span>
          <span class="svc-tag">Integraciones</span>
          <span class="svc-tag">Gestión de leads</span>
        </div>
      </div>
    </div>

    <!-- Card 3 — Estrategia digital -->
    <div class="svc svc-3" style="background:#1a1a1e;" data-svc-card>
      <img src="/images/svc-5.jpg" alt="Estrategia digital" class="svc-img" />
      <div class="svc-content">
        <span class="svc-badge">
          03
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <circle cx="12" cy="12" r="6"/>
            <circle cx="12" cy="12" r="2"/>
          </svg>
        </span>
        <h3 class="svc-title">Estrategia digital</h3>
        <p class="svc-desc">Antes de hablar de qué publicar, queremos entenderte. Con eso como base, definimos qué comunicar, a quién y cómo, para que cada acción tenga un propósito real.</p>
        <div class="svc-tags">
          <span class="svc-tag">Identidad de marca</span>
          <span class="svc-tag">Plan de contenidos</span>
          <span class="svc-tag">Posicionamiento</span>
        </div>
      </div>
    </div>

    <!-- Card 4 — Producción de contenido visual -->
    <div class="svc svc-4" style="background:#2d1f3d;" data-svc-card>
      <img src="/images/svc-2.jpg" alt="Contenido visual" class="svc-img" />
      <div class="svc-content">
        <span class="svc-badge">
          04
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
        </span>
        <h3 class="svc-title">Producción de contenido visual</h3>
        <p class="svc-desc">Creamos el contenido, lo organizamos y te lo dejamos listo para publicar. Vos elegís hasta dónde involucrarte. Nosotros hacemos que funcione.</p>
        <div class="svc-tags">
          <span class="svc-tag">Fotografía</span>
          <span class="svc-tag">Reels</span>
          <span class="svc-tag">Posts</span>
          <span class="svc-tag">Calendario</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .services {
    background: #0a0a0a;
    overflow: hidden;
  }

  /* ── Header ── */
  .services-header {
    padding: clamp(60px, 8vw, 120px) clamp(24px, 4vw, 80px) 40px;
  }

  .services-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-purple-deep);
    margin-bottom: 16px;
  }

  .services-title {
    font-family: var(--font-serif);
    font-size: clamp(28px, 4vw, 44px);
    color: #f0ede6;
    line-height: 1.15;
    max-width: 640px;
  }

  .services-title em {
    font-style: italic;
    color: var(--color-purple-deep);
    -webkit-text-fill-color: var(--color-purple-deep);
    background: none;
    -webkit-background-clip: unset;
    background-clip: unset;
  }

  /* ── Track ── */
  .services-track {
    display: flex;
    gap: 10px;
    padding: 0 clamp(24px, 4vw, 80px) clamp(40px, 5vw, 80px);
    will-change: transform;
  }

  /* ── Base card ── */
  .svc {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    cursor: default;
    border: 1px solid rgba(255, 255, 255, 0.07);
    transition: border-color 0.3s;
    transform-style: preserve-3d;
    will-change: transform;
    flex-shrink: 0;
  }

  .svc:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  /* Desktop card sizes */
  @media (min-width: 1025px) {
    .svc-1 { width: 540px; height: 520px; }
    .svc-2 { width: 400px; height: 520px; }
    .svc-3 { width: 400px; height: 520px; justify-content: center; }
    .svc-4 { width: 400px; height: 520px; justify-content: center; }
  }

  /* ── Grain overlay ── */
  .svc::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.04;
    mix-blend-mode: overlay;
    pointer-events: none;
    z-index: 4;
  }

  /* ── Images ── */
  .svc-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    object-fit: cover;
    border-radius: 12px 12px 0 0;
    z-index: 1;
  }

  /* svc-1: image top 50% */
  .svc-1 .svc-img { height: 50%; }

  /* svc-2: full-width image at top */
  .svc-2 .svc-img {
    width: 100%;
    height: 46%;
    border-radius: 12px 12px 0 0;
    object-position: center 65%;
  }

  /* svc-3: image on left side */
  .svc-3 .svc-img {
    width: 42%;
    height: 100%;
    border-radius: 12px 0 0 12px;
    left: 0;
    right: auto;
    object-fit: cover;
  }

  /* svc-4: image on right side */
  .svc-4 .svc-img {
    width: 42%;
    height: 100%;
    border-radius: 0 12px 12px 0;
    left: auto;
    right: 0;
    object-fit: cover;
  }

  /* ── Gradient overlays ── */
  .svc::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .svc-1::before { background: linear-gradient(to bottom, transparent 20%, #2a2a2a 58%); }
  .svc-2::before { background: linear-gradient(to bottom, transparent 50%, rgba(58, 47, 30, 0.6) 100%); }
  .svc-3::before { background: linear-gradient(to left, #1a1a1e 42%, transparent 85%); }
  .svc-4::before { background: linear-gradient(to right, #2d1f3d 42%, transparent 85%); }

  /* ── Content ── */
  .svc-content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .svc-3 .svc-content,
  .svc-4 .svc-content {
    max-width: 56%;
  }

  .svc-3 .svc-content { margin-left: auto; }

  /* ── Inline header (svc-2) ── */
  .svc-inline-header {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .svc-inline-header .svc-title {
    font-size: clamp(17px, 1.6vw, 22px);
  }

  /* ── Badge ── */
  .svc-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 4px 8px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 20px;
    width: fit-content;
    font-family: var(--font-sans);
    font-size: 11px;
    color: #f0ede6;
  }

  .svc-badge svg { width: 14px; height: 14px; }

  .svc-1 .svc-badge svg { color: #a09a8e; }
  .svc-2 .svc-badge svg { color: #c49a4a; }
  .svc-3 .svc-badge svg { color: #a09a8e; }
  .svc-4 .svc-badge svg { color: #b89fd4; }

  /* ── Title ── */
  .svc-title {
    font-family: var(--font-serif);
    color: #f0ede6;
    line-height: 1.15;
    margin: 0;
  }

  .svc-1 .svc-title { font-size: clamp(24px, 2.8vw, 36px); }
  .svc-2 .svc-title,
  .svc-3 .svc-title,
  .svc-4 .svc-title { font-size: clamp(17px, 1.6vw, 22px); }

  /* ── Desc ── */
  .svc-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    color: #a09a8e;
    line-height: 1.5;
    margin: 0;
  }

  /* ── Tags ── */
  .svc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 4px;
  }

  .svc-tag {
    font-family: var(--font-sans);
    font-size: 10px;
    color: #d0c8bc;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 6px;
    padding: 3px 8px;
  }

  .svc-2 .svc-tag { border-color: rgba(196, 154, 74, 0.35); }
  .svc-4 .svc-tag { border-color: rgba(184, 159, 212, 0.35); }

  /* ── Arrow (svc-1 only) ── */
  .svc-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #f0ede6;
    font-size: 18px;
    margin-top: 8px;
    transition: border-color 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .svc:hover .svc-arrow {
    transform: translate(2px, -2px);
    border-color: rgba(255, 255, 255, 0.7);
  }

  /* ── Tablet (769px–1024px) ── */
  @media (max-width: 1024px) {
    .services-track {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      gap: 8px;
    }

    .svc-1 { grid-column: 1 / 3; height: 400px; }
    .svc-2,
    .svc-3,
    .svc-4 { height: 280px; }

    /* Revert side images to top on tablet */
    .svc-3 .svc-img,
    .svc-4 .svc-img {
      width: 100%;
      height: 40%;
      border-radius: 12px 12px 0 0;
      left: 0;
      right: auto;
    }

    .svc-3,
    .svc-4 { justify-content: flex-end; }

    .svc-3 .svc-content,
    .svc-4 .svc-content { max-width: 100%; margin-left: 0; }

    .svc-3::before { background: linear-gradient(to bottom, transparent 25%, #1a1a1e 55%); }
    .svc-4::before { background: linear-gradient(to bottom, transparent 25%, #2d1f3d 55%); }
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .services-header { padding: 60px 20px 32px; }

    .svc-arrow { display: none !important; }

    .services-track {
      display: flex !important;
      flex-direction: column;
      padding: 0 16px 60px;
      gap: 8px;
    }

    .svc {
      display: block !important;
      padding: 0 !important;
      height: auto !important;
    }

    .svc-1 .svc-img,
    .svc-2 .svc-img,
    .svc-3 .svc-img,
    .svc-4 .svc-img {
      position: relative !important;
      height: 180px !important;
      width: 100% !important;
      border-radius: 12px 12px 0 0;
    }

    .svc-2 .svc-img {
      object-fit: contain !important;
      object-position: center center !important;
      height: 160px !important;
    }

    .svc::before { display: none !important; }

    .svc-content {
      padding: 16px 18px 18px;
      max-width: 100% !important;
      margin-left: 0 !important;
    }

    .svc-3,
    .svc-4 { justify-content: flex-end !important; }

    .svc-tags { margin-top: 8px !important; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isDesktop = window.innerWidth >= 1025;
  const cards = gsap.utils.toArray<HTMLElement>('[data-svc-card]');

  if (prefersReducedMotion) {
    gsap.set(cards, { autoAlpha: 1, y: 0 });
    gsap.set('[data-svc-card] .svc-tag', { autoAlpha: 1, scale: 1 });

  } else if (isDesktop) {
    // ── Horizontal scroll ──────────────────────────────────────────
    const track = document.querySelector<HTMLElement>('.services-track')!;
    const section = document.querySelector<HTMLElement>('.services')!;

    gsap.set(cards, { autoAlpha: 0, y: 36 });
    gsap.set('[data-svc-card] .svc-tag', { autoAlpha: 0, scale: 0.7 });

    const scrollTween = gsap.to(track, {
      x: () => -(track.scrollWidth - window.innerWidth),
      ease: 'none',
      scrollTrigger: {
        trigger: section,
        pin: true,
        start: 'top top',
        end: () => '+=' + (track.scrollWidth - window.innerWidth),
        scrub: 1.2,
        invalidateOnRefresh: true,
      },
    });

    // Reveal each card as it enters the viewport horizontally
    cards.forEach((card) => {
      gsap.to(card, {
        autoAlpha: 1,
        y: 0,
        duration: 0.7,
        ease: 'power3.out',
        scrollTrigger: {
          containerAnimation: scrollTween,
          trigger: card,
          start: 'left 92%',
          toggleActions: 'play none none none',
        },
        onComplete() {
          const tags = card.querySelectorAll<HTMLElement>('.svc-tag');
          if (tags.length) {
            gsap.fromTo(
              tags,
              { autoAlpha: 0, scale: 0.7 },
              { autoAlpha: 1, scale: 1, duration: 0.3, stagger: 0.05, ease: 'back.out(1.7)' }
            );
          }
        },
      });
    });

    // 3D tilt on hover
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const rotateX = (((e.clientY - rect.top) / rect.height) - 0.5) * -12;
        const rotateY = (((e.clientX - rect.left) / rect.width) - 0.5) * 12;
        gsap.to(card, { rotateX, rotateY, scale: 1.02, transformPerspective: 800, ease: 'power1.out', duration: 0.4 });
      });
      card.addEventListener('mouseleave', () => {
        gsap.to(card, { rotateX: 0, rotateY: 0, scale: 1, duration: 0.6, ease: 'elastic.out(1, 0.5)' });
      });
    });

  } else {
    // ── Mobile / tablet: simple scroll reveal ─────────────────────
    gsap.set(cards, { autoAlpha: 0, y: 40 });
    gsap.set('[data-svc-card] .svc-tag', { autoAlpha: 0, scale: 0.7 });

    cards.forEach((card, i) => {
      gsap.to(card, {
        autoAlpha: 1,
        y: 0,
        duration: 0.7,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 85%',
          once: true,
        },
        onComplete() {
          const tags = card.querySelectorAll<HTMLElement>('.svc-tag');
          if (tags.length) {
            gsap.fromTo(
              tags,
              { autoAlpha: 0, scale: 0.7 },
              { autoAlpha: 1, scale: 1, duration: 0.3, stagger: 0.05, ease: 'back.out(1.7)' }
            );
          }
        },
      });
    });
  }
</script>
