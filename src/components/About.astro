---
---

<section class="about" id="nosotros">
  <div class="about-inner">
    <!-- Left: text + team cards -->
    <div class="about-text">
      <p class="section-label" data-animate>Dos personas. Un equipo completo.</p>
      <h2 class="section-title" data-split-text>Somos Thomas y Mai. <em>El equipo</em> que ejecuta.</h2>
      <p class="about-desc" data-animate>
        Él desarrolla, automatiza y hace que las cosas funcionen. Ella crea, fotografía y hace que las cosas se vean bien. Juntos ofrecemos lo que normalmente requeriría contratar a tres personas distintas — con la ventaja de que siempre hablás con quien realmente hace el trabajo.
      </p>
      <p class="about-desc" data-animate>
        No somos una agencia grande con cuentas y coordinadores. Somos el equipo que ejecuta, y eso se nota en los resultados.
      </p>
      <div class="about-team">
        <div class="team-card" data-animate>
          <div class="team-avatar team-avatar-1">👨‍💻</div>
          <div class="team-name">Thomas</div>
          <div class="team-role">Desarrollo & Automatización</div>
          <div class="team-bio" style="font-size:12px;color:var(--color-ink-muted);line-height:1.6;margin-bottom:10px;">Desarrollo web moderno, integraciones y flujos automatizados para que tu negocio opere más eficientemente.</div>
          <div class="team-skills">
            <span class="team-skill">Astro</span>
            <span class="team-skill">React</span>
            <span class="team-skill">n8n</span>
            <span class="team-skill">IA</span>
          </div>
        </div>
        <div class="team-card" data-animate>
          <div class="team-avatar team-avatar-2">👩‍🎨</div>
          <div class="team-name">Mai</div>
          <div class="team-role">Contenido Visual & Estrategia</div>
          <div class="team-bio" style="font-size:12px;color:var(--color-ink-muted);line-height:1.6;margin-bottom:10px;">Producción fotográfica y de video, edición de reels y estrategia de contenido que conecta con tu audiencia.</div>
          <div class="team-skills">
            <span class="team-skill">Fotografía</span>
            <span class="team-skill">Video</span>
            <span class="team-skill">Reels</span>
            <span class="team-skill">Estrategia de contenido</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: stat cards -->
    <div class="about-visual">
      <!-- Card 1: Active clients -->
      <div class="av-card av-1" data-animate>
        <div class="av-label">PROYECTOS COMPLETADOS</div>
        <div class="av-val"><span data-counter="6">0</span>+</div>
        <div class="av-sub">negocios que ya crecen con nosotros</div>
        <div class="av-bar-row">
          <div class="av-bar">
            <div class="av-bar-fill av-bar-fill-purple" style="width: 85%"></div>
          </div>
          <div class="av-bar">
            <div class="av-bar-fill av-bar-fill-green" style="width: 70%"></div>
          </div>
          <div class="av-bar">
            <div class="av-bar-fill av-bar-fill-light" style="width: 92%"></div>
          </div>
        </div>
      </div>

      <!-- Card 2: Delivery time -->
      <div class="av-card av-2" data-animate>
        <div class="av-label av-label-dark">ENTREGA</div>
        <div class="av-val av-val-purple" style="font-size:18px;line-height:1.3;">Tu web lista</div>
        <div class="av-sub av-sub-dark">en días, no en semanas</div>
      </div>

      <!-- Card 3: Free audit -->
      <div class="av-card av-3" data-animate>
        <div class="av-label av-label-purple">AUDITORÍA</div>
        <div class="av-val-sm">Gratis</div>
        <div class="av-sub-sm">Analizamos tu presencia digital sin costo</div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: #0A0A0A;
    padding: 120px 48px;
  }

  .about-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .about-text .section-title {
    margin-bottom: 24px;
  }

  .about-desc {
    font-size: 16px;
    color: var(--color-ink-muted);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 40px;
  }

  .about-team {
    display: flex;
    gap: 16px;
  }

  .team-card {
    flex: 1;
    background: #1C1C1A;
    border-radius: 16px;
    padding: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .team-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .team-avatar-1 {
    background: var(--color-purple-light);
  }

  .team-avatar-2 {
    background: var(--color-green-light);
  }

  .team-name {
    font-family: var(--font-serif);
    font-size: 18px;
    margin-bottom: 4px;
    color: var(--color-ink);
  }

  .team-role {
    font-size: 12px;
    color: var(--color-ink-muted);
    margin-bottom: 10px;
  }

  .team-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .team-skill {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 3px 10px;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.07);
    color: var(--color-ink-muted);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Visual stat cards */
  .about-visual {
    position: relative;
    height: 480px;
  }

  .av-card {
    position: absolute;
    background: #1C1C1A;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .av-1 {
    width: 260px;
    top: 0;
    left: 0;
  }

  .av-2 {
    width: 220px;
    top: 120px;
    right: 0;
    background: var(--color-ink-soft);
    color: var(--color-cream);
    border-color: transparent;
  }

  .av-3 {
    width: 200px;
    bottom: 0;
    left: 40px;
    background: #2A2340;
    border-color: rgba(123, 107, 176, 0.2);
  }

  .av-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    opacity: 0.5;
    margin-bottom: 8px;
  }

  .av-label-dark {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: rgba(247, 244, 239, 0.4);
    margin-bottom: 8px;
  }

  .av-label-purple {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-purple-deep);
    opacity: 0.7;
    margin-bottom: 8px;
  }

  .av-val {
    font-family: var(--font-serif);
    font-size: 28px;
    line-height: 1;
    margin-bottom: 4px;
    color: #FFFFFF;
  }

  .av-val-purple {
    font-family: var(--font-serif);
    font-size: 28px;
    line-height: 1;
    margin-bottom: 4px;
    color: var(--color-purple);
  }

  .av-val-sm {
    font-family: var(--font-serif);
    font-size: 20px;
    color: #FFFFFF;
    line-height: 1;
    margin-bottom: 4px;
  }

  .av-sub {
    font-size: 12px;
    opacity: 0.5;
  }

  .av-sub-dark {
    font-size: 12px;
    color: rgba(247, 244, 239, 0.4);
  }

  .av-sub-sm {
    font-size: 11px;
    color: var(--color-ink-muted);
    margin-top: 4px;
  }

  .av-bar-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 12px;
  }

  .av-bar {
    height: 4px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.1);
    overflow: hidden;
  }

  .av-bar-fill {
    height: 100%;
    border-radius: 2px;
  }

  .av-bar-fill-purple {
    background: var(--color-purple);
  }

  .av-bar-fill-green {
    background: var(--color-green);
  }

  .av-bar-fill-light {
    background: rgba(184, 169, 217, 0.5);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .about-visual {
      height: 360px;
    }

    .av-1 {
      width: 220px;
    }

    .av-2 {
      width: 180px;
      top: 100px;
    }

    .av-3 {
      width: 160px;
    }
  }

  @media (max-width: 600px) {
    .about {
      padding: 80px 24px;
    }

    .about-team {
      flex-direction: column;
    }
  }
</style>
