        <div class="clink-text">
          <div class="clink-label">INSTAGRAM</div>
          <div class="clink-val">@calaxstudio</div>
        </div>
        <span class="clink-arrow">→</span>
      </a>
    </div>
  </div>

  <!-- Right: contact form -->
  <div class="contact-form" data-animate>
    <div class="form-title">Empecemos</div>
    <form
      action="https://formspree.io/f/xpqodprk"
      method="POST"
    >
      <input type="hidden" name="_subject" value="Nueva auditoría gratuita — Calax Studio" />

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="name">Nombre</label>
          <input
            type="text"
            id="name"
            name="nombre"
            class="form-input"
            placeholder="Tu nombre"
            required
          />
        </div>
        <div class="form-group">
          <label class="form-label" for="business">Negocio / Rubro</label>
          <input
            type="text"
            id="business"
            name="negocio"
            class="form-input"
            placeholder="Nombre del negocio o rubro"
          />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="contacto">Contacto</label>
        <input
          type="text"
          id="contacto"
          name="contacto"
          class="form-input"
          placeholder="Email o WhatsApp (ej: +54 9 11 1234-5678)"
          required
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="message">Mensaje</label>
        <textarea
          id="message"
          name="mensaje"
          class="form-input"
          placeholder="¿Qué es lo más urgente que querés mejorar de tu presencia online?"
        ></textarea>
      </div>

      <button type="submit" class="form-submit">
        Solicitar auditoría gratuita →
      </button>
      <p class="form-microcopy">Te respondemos en menos de 24 horas. Garantizado.</p>
    </form>
  </div>
</section>

<style>
  .contact {
    padding: 120px 48px;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: stretch;
  }

  .contact-title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
    color: var(--color-ink);
  }

  .contact-title em {
    font-style: italic;
    color: var(--color-purple-deep);
  }

  .contact-sub {
    font-size: 16px;
    color: var(--color-ink-muted);
    line-height: 1.7;
    font-weight: 300;
    margin-bottom: 36px;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .clink {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 14px;
    color: #FFFFFF;
    text-decoration: none;
    padding: 16px 20px;
    background: #1C1C1A;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: background 0.2s, transform 0.15s;
  }

  .clink:hover {
    background: #2A2340;
    border-color: rgba(123, 107, 176, 0.3);
    transform: translateX(4px);
  }

  /* WhatsApp dominant card */
  .clink--whatsapp {
    border: 1px solid rgba(184, 169, 217, 0.5);
    padding: 20px 24px;
  }

  /* Muted cards for Email and Instagram */
  .clink--muted .clink-icon,
  .clink--muted .clink-text {
    opacity: 0.7;
  }

  .clink-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }

  .clink-icon-1 {
    background: var(--color-green-light);
  }

  .clink-icon-2 {
    background: #2A2340;
  }

  .clink-icon-3 {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .clink-text {
    flex: 1;
  }

  .clink-label {
    font-size: 11px;
    color: var(--color-ink-muted);
    margin-bottom: 2px;
    letter-spacing: 0.04em;
  }

  .clink-val {
    font-weight: 500;
  }

  .clink-arrow {
    color: var(--color-ink-muted);
    font-size: 14px;
  }

  .clink-badge {
    font-size: 10px;
    font-weight: 500;
    color: rgba(184, 169, 217, 0.9);
    background: rgba(184, 169, 217, 0.15);
    padding: 3px 8px;
    border-radius: 100px;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* Form */
  .contact-form {
    background: var(--color-ink-soft);
    border-radius: 24px;
    padding: 40px;
    color: var(--color-cream);
    height: 100%;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .contact-form form {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .form-title {
    font-family: var(--font-serif);
    font-size: 24px;
    margin-bottom: 28px;
    color: var(--color-cream);
  }

  .form-group {
    margin-bottom: 18px;
  }

  .form-label {
    font-size: 12px;
    color: rgba(247, 244, 239, 0.7);
    letter-spacing: 0.04em;
    margin-bottom: 8px;
    display: block;
  }

  .form-input {
    width: 100%;
    padding: 13px 16px;
    background: rgba(247, 244, 239, 0.08);
    border: 1px solid rgba(247, 244, 239, 0.22);
    border-radius: 10px;
    color: var(--color-cream);
    font-family: var(--font-sans);
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .form-input::placeholder {
    color: rgba(247, 244, 239, 0.4);
  }

  .form-input:focus {
    border-color: var(--color-purple);
    background: rgba(247, 244, 239, 0.13);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  textarea.form-input {
    resize: none;
    flex: 1;
    min-height: 100px;
  }

  .form-group:has(textarea) {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .form-submit {
    width: 100%;
    padding: 14px;
    background: var(--color-purple-deep);
    color: white;
    border: none;
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    margin-top: 8px;
    transition: background 0.2s, transform 0.15s;
  }

  .form-submit:hover {
    background: #6B5BA0;
    transform: translateY(-1px);
  }

  .form-microcopy {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
    margin-top: 8px;
    margin-bottom: 0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .contact {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  @media (max-width: 600px) {
    .contact {
      padding: 80px 24px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form {
      padding: 28px 24px;
    }
  }
</style>
