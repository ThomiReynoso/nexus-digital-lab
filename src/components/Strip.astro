---
const items = [
  'Desarrollo web',
  'Gestión de redes',
  'Fotografía de producto',
  'Reels & video',
  'Estrategia digital',
  'E-commerce',
];
---

<div class="strip">
  <div class="strip-inner">
    {items.map((item) => (
      <span class="strip-item">{item}</span>
    ))}
    {/* Duplicate for seamless loop */}
    {items.map((item) => (
      <span class="strip-item">{item}</span>
    ))}
  </div>
</div>

<style>
  .strip {
    background: var(--color-ink);
    padding: 18px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .strip-inner {
    display: inline-flex;
    gap: 48px;
    animation: marquee 20s linear infinite;
  }

  .strip-item {
    font-size: 13px;
    color: rgba(247, 244, 239, 0.45);
    font-weight: 300;
    letter-spacing: 0.1em;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .strip-item::after {
    content: '·';
    color: var(--color-purple);
  }
</style>
