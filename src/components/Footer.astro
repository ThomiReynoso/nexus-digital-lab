---
const links = [
  { text: 'Servicios', href: '#servicios' },
  { text: 'Portfolio', href: '#portfolio' },
  { text: 'Proceso', href: '#proceso' },
  { text: 'Contacto', href: '#contacto' },
];
---

<footer class="footer">
  <!-- Gradient separator line -->
  <div class="footer-gradient-line"></div>

  <div class="footer-inner">
    <div class="footer-logo">
      <span class="footer-letter" style="overflow: hidden; display: inline-block;"><span class="footer-letter-inner" style="display: inline-block;">C</span></span>
      <span class="footer-letter" style="overflow: hidden; display: inline-block;"><span class="footer-letter-inner" style="display: inline-block;">a</span></span>
      <span class="footer-letter" style="overflow: hidden; display: inline-block;"><span class="footer-letter-inner" style="display: inline-block;">l</span></span>
      <span class="footer-letter" style="overflow: hidden; display: inline-block;"><span class="footer-letter-inner" style="display: inline-block;">a</span></span>
      <span class="footer-letter" style="overflow: hidden; display: inline-block; color: var(--color-purple);"><span class="footer-letter-inner" style="display: inline-block;">x</span></span>
      <span style="display: inline-block; width: 0.3em;"> </span>
      <span class="footer-letter" style="overflow: hidden; display: inline-block;"><span class="footer-letter-inner" style="display: inline-block;">S</span></span>
      <span class="footer-letter" style="overflow: hidden; display: inline-block;"><span class="footer-letter-inner" style="display: inline-block;">t</span></span>
      <span class="footer-letter" style="overflow: hidden; display: inline-block;"><span class="footer-letter-inner" style="display: inline-block;">u</span></span>
      <span class="footer-letter" style="overflow: hidden; display: inline-block;"><span class="footer-letter-inner" style="display: inline-block;">d</span></span>
      <span class="footer-letter" style="overflow: hidden; display: inline-block;"><span class="footer-letter-inner" style="display: inline-block;">i</span></span>
      <span class="footer-letter" style="overflow: hidden; display: inline-block;"><span class="footer-letter-inner" style="display: inline-block;">o</span></span>
    </div>

    <nav class="footer-links">
      {links.map((link) => (
        <a class="footer-link" href={link.href}>{link.text}</a>
      ))}
    </nav>

    <div class="footer-center">Hecho con 💜 en Barcelona · Eixample</div>
    <div class="footer-copy">© 2026 Calax Studio. Todos los derechos reservados.</div>
  </div>
</footer>

<style>
  .footer {
    background: #0A0A0A;
    position: relative;
  }

  /* ─── Gradient separator ─── */
  .footer-gradient-line {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-purple) 30%,
      var(--color-green) 70%,
      transparent 100%
    );
    opacity: 0.5;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    padding: 48px;
    color: rgba(247, 244, 239, 0.35);
    font-size: 13px;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ─── Logo with per-letter hover ─── */
  .footer-logo {
    font-family: var(--font-serif);
    font-size: 24px;
    color: var(--color-cream);
    margin-bottom: 8px;
  }

  .footer-letter {
    transition: color 0.3s ease, transform 0.3s ease;
    cursor: default;
  }

  .footer-letter:hover {
    color: var(--color-purple) !important;
  }

  .footer-letter:hover .footer-letter-inner {
    transform: translateY(-3px);
    transition: transform 0.3s ease;
  }

  /* ─── Footer links with animated underline ─── */
  .footer-links {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-link {
    color: rgba(247, 244, 239, 0.55);
    text-decoration: none;
    font-size: 13px;
    font-weight: 400;
    position: relative;
    padding-bottom: 2px;
    transition: color 0.3s ease;
  }

  .footer-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--color-purple), var(--color-green));
    transition: width 0.4s ease;
  }

  .footer-link:hover {
    color: var(--color-cream);
  }

  .footer-link:hover::after {
    width: 100%;
  }

  .footer-center {
    font-size: 13px;
  }

  .footer-copy {
    font-size: 12px;
    opacity: 0.6;
  }

  /* ─── Responsive ─── */
  @media (max-width: 600px) {
    .footer-inner {
      padding: 40px 24px;
      gap: 20px;
    }
    .footer-links {
      gap: 20px;
    }
  }
</style>
