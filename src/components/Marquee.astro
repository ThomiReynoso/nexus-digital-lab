<div class="marquee-strip" aria-hidden="true">
  <div class="marquee-track">
    <span class="marquee-text">
      DISEÑO WEB <span class="dot">·</span> BARCELONA <span class="dot">·</span> CONTENIDO DIGITAL <span class="dot">·</span> FOTOGRAFÍA <span class="dot">·</span> AUTOMATIZACIÓN <span class="dot">·</span> ESTRATEGIA DIGITAL <span class="dot">·</span>&nbsp;
    </span>
    <span class="marquee-text" aria-hidden="true">
      DISEÑO WEB <span class="dot">·</span> BARCELONA <span class="dot">·</span> CONTENIDO DIGITAL <span class="dot">·</span> FOTOGRAFÍA <span class="dot">·</span> AUTOMATIZACIÓN <span class="dot">·</span> ESTRATEGIA DIGITAL <span class="dot">·</span>&nbsp;
